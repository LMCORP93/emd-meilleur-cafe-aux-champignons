---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BlogHero from '@/components/BlogHero.astro';
import TableOfContents from '@/components/TableOfContents.astro';
import ComparatorCard from '@/components/ComparatorCard.astro';
import SidebarCTA from '@/components/SidebarCTA.astro';
import ArticleGrid from '@/components/ArticleGrid.astro';
import config from '@/data/site.config';

const topProduct = config.products[0];

const sampleArticles = [
  {
    title: 'Les meilleurs compléments alimentaires en 2026',
    excerpt: 'Notre sélection des produits les plus efficaces pour votre bien-être quotidien.',
    image: '/logo.svg',
    href: '/',
  },
  {
    title: 'Comment choisir un complément de qualité ?',
    excerpt: 'Les critères essentiels pour identifier un produit fiable et efficace.',
    image: '/logo.svg',
    href: '/',
  },
  {
    title: 'Guide complet sur les vitamines essentielles',
    excerpt: 'Tout ce que vous devez savoir sur les vitamines et leurs bienfaits.',
    image: '/logo.svg',
    href: '/',
  },
];
---

<BaseLayout
  title={`Comparatif ${config.productCategory} 2026 — ${config.siteName}`}
  description={`Découvrez notre comparatif complet des meilleurs ${config.productCategory}. Tests, avis et codes promo exclusifs.`}
>
  <!-- JSON-LD: ItemList -->
  <script type="application/ld+json" slot="json-ld" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "itemListElement": config.products.map((p, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "item": {
        "@type": "Product",
        "name": p.name,
        "image": p.image,
        "brand": { "@type": "Brand", "name": p.brand },
        "offers": {
          "@type": "Offer",
          "priceCurrency": "EUR",
          "price": p.discountPrice.replace(/[^\d.,]/g, '').replace(',', '.'),
          "availability": "https://schema.org/InStock",
          "url": p.affiliateLink,
        },
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": p.rating,
          "bestRating": 10,
          "reviewCount": p.reviewCount,
        },
      },
    })),
  })} />

  <!-- Blog Hero -->
  <BlogHero
    title={`Comparatif ${config.productCategory} 2026`}
    description="Découvrez le classement des meilleurs produits. Notre analyse détaillée vous aide à faire le bon choix."
    author={config.author.name}
    authorAvatar={config.author.avatar}
    date="15 Janvier 2026"
    readingTime="12 min de lecture"
    bannerImage="/banner-placeholder.jpg"
    breadcrumbs={[
      { label: 'Accueil', href: '/' },
      { label: 'Comparatif', href: '/comparatif' },
    ]}
    product={{
      name: topProduct.name,
      image: topProduct.image,
      promoCode: topProduct.promoCode,
      promoPercent: topProduct.promoPercent,
      originalPrice: topProduct.originalPrice,
      discountPrice: topProduct.discountPrice,
      affiliateLink: topProduct.affiliateLink,
    }}
  />

  <main style="background-color: #ffffff;">
    <div class="container-medium padding-global">
      <div class="padding-section-medium">
        <div class="blog-grid">

          <!-- ═══ LEFT COLUMN (cards) ═══ -->
          <div class="content-column">

            <!-- Intro -->
            <section id="introduction" class="mb-8">
              <div class="rich-text">
                <h2>Notre comparatif {config.productCategory}</h2>
                <p>
                  Vous recherchez le meilleur {config.product.toLowerCase()} du marché ? Notre équipe a testé et analysé les produits les plus populaires pour vous aider à choisir. Découvrez notre classement complet avec nos recommandations personnalisées.
                </p>
              </div>
            </section>

            <!-- Table of Contents -->
            <TableOfContents items={[
              { id: 'introduction', label: 'Introduction' },
              ...config.products.map((p) => ({
                id: `product-${p.slug}`,
                label: `${p.rank <= 3 ? (p.rank === 1 ? '🏆' : p.rank === 2 ? '🥈' : '🥉') : ''} Top ${p.rank} — ${p.brand}`,
              })),
            ]} />

            <!-- Comparator Cards -->
            <section id="comparatif-section" class="comparatif-cards">
              {config.products.map((product) => (
                <div id={`product-${product.slug}`}>
                  <ComparatorCard product={product} />
                </div>
              ))}
            </section>
          </div>

          <!-- ═══ RIGHT COLUMN (sidebar) ═══ -->
          <div class="sidebar-column">
            <div class="sidebar-sticky">
              <SidebarCTA
                logoSrc={topProduct.brandLogo}
                promoCode={topProduct.promoCode}
                promoPercent={topProduct.promoPercent}
                originalPrice={topProduct.originalPrice}
                discountPrice={topProduct.discountPrice}
                ctaLink={topProduct.affiliateLink}
                heroImage={topProduct.image}
                rating={topProduct.rating}
                reviewCount={topProduct.reviewCount}
              />
            </div>
          </div>

        </div>
      </div>
    </div>
  </main>

  <!-- Article Grid -->
  <ArticleGrid articles={sampleArticles} />
</BaseLayout>

<style>
  .comparatif-cards {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
</style>
