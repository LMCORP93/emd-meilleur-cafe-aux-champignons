---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Contactez Le Meilleur Complement.">
  <main class="padding-section-medium" style="background-color: #ffffff;">
    <div class="container-large" style="max-width: 72rem; margin: 0 auto;">

      <h1 style="font-size: clamp(1.75rem, 1.2rem + 2.75vw, 2.5rem); color: #242424; margin-bottom: 2rem;">Contact</h1>

      <div style="color: #333; line-height: 1.8; font-size: 14px; max-width: 48rem;">

        <p style="margin-bottom: 1.5rem;">Une question, une suggestion ou une demande de partenariat ? N'hésitez pas à nous contacter.</p>

        <h2 style="font-size: clamp(1.25rem, 1.1rem + 0.75vw, 1.5rem); color: #242424; margin-top: 2rem; margin-bottom: 0.75rem;">Éditeur</h2>
        <p>
          <strong>SARL LMCORP</strong> - SARL<br>
          Siège social : Quartier Industriel Sidi Ghanem, Lot N°208, Bureau N°DH7, Marrakech, Maroc<br>
          ICE : 003858984000079
        </p>

        <h2 style="font-size: clamp(1.25rem, 1.1rem + 0.75vw, 1.5rem); color: #242424; margin-top: 2rem; margin-bottom: 0.75rem;">Email</h2>
        <p>
          <strong>contact@le-meilleur-complement.fr</strong>
        </p>

      </div>
    </div>
  </main>
</BaseLayout>
