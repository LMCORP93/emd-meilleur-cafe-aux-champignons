---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BlogHero from '@/components/BlogHero.astro';
import FirstReview from '@/components/FirstReview.astro';
import TableOfContents from '@/components/TableOfContents.astro';
import ImageBlock from '@/components/ImageBlock.astro';
import ComparisonTable from '@/components/ComparisonTable.astro';
import ReviewPromoCard from '@/components/ReviewPromoCard.astro';
import InnerNote from '@/components/InnerNote.astro';
import FaqAccordion from '@/components/FaqAccordion.astro';
import SidebarCTA from '@/components/SidebarCTA.astro';
import ArticleGrid from '@/components/ArticleGrid.astro';
import EditorialCriteria from '@/components/EditorialCriteria.astro';
import config from '@/data/site.config';

const topProduct = config.products[0];

const sampleArticles = [
  {
    title: 'Les meilleurs compléments alimentaires en 2026',
    excerpt: 'Notre sélection des produits les plus efficaces pour votre bien-être quotidien.',
    image: '/logo.svg',
    href: '/',
  },
  {
    title: 'Comment choisir un complément de qualité ?',
    excerpt: 'Les critères essentiels pour identifier un produit fiable et efficace.',
    image: '/logo.svg',
    href: '/',
  },
  {
    title: 'Guide complet sur les vitamines essentielles',
    excerpt: 'Tout ce que vous devez savoir sur les vitamines et leurs bienfaits.',
    image: '/logo.svg',
    href: '/',
  },
];
---

<BaseLayout title={config.seo.title} description={config.seo.description} ogImage={config.seo.ogImage}>
  <!-- JSON-LD -->
  <script type="application/ld+json" slot="json-ld" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": config.seo.title,
    "description": config.seo.description,
    "author": {
      "@type": "Person",
      "name": config.author.name,
    },
    "publisher": {
      "@type": "Organization",
      "name": config.siteName,
    },
    "datePublished": "2026-01-15",
    "dateModified": "2026-04-07",
  })} />

  <!-- Blog Hero -->
  <BlogHero
    title={config.seo.title}
    description={config.seo.description}
    author={config.author.name}
    authorAvatar={config.author.avatar}
    date="15 Janvier 2026"
    readingTime="10 min de lecture"
    bannerImage="/banner-placeholder.jpg"
    product={{
      name: topProduct.name,
      image: topProduct.image,
      promoCode: topProduct.promoCode,
      promoPercent: topProduct.promoPercent,
      originalPrice: topProduct.originalPrice,
      discountPrice: topProduct.discountPrice,
      affiliateLink: topProduct.affiliateLink,
    }}
  />

  <main class="padding-section-medium" style="background-color: #ffffff;">
    <div class="container-large padding-global">
      <div class="blog-grid">

        <!-- ═══ LEFT COLUMN (content) ═══ -->
        <div class="content-column">

          <!-- 1. Quick Summary (En bref) -->
          <FirstReview
            tag="En bref"
            heading="Résumé rapide du Lorem Supplement"
            paragraphs={[
              "Le Lorem Supplement est notre coup de cœur pour 2026. Avec une composition naturelle certifiée et des résultats cliniquement prouvés, il se démarque nettement de la concurrence.",
              "Après des semaines de tests, notre verdict est sans appel : excellent rapport qualité-prix grâce à notre code promo exclusif."
            ]}
            assets={config.quickSummary.assets}
            considerations={config.quickSummary.considerations}
            product={{
              brandName: "Mush N Go",
              brandLogoSrc: "/logo-mushngo.svg",
              rating: topProduct.rating,
              reviewLabel: "Meilleur choix 2026",
              ctaText: "En savoir plus",
              ctaLink: topProduct.affiliateLink,
            }}
          />

          <!-- 2. Rich Text — H2 #1: Introduction -->
          <section id="introduction" class="content-section">
            <div class="rich-text">
              <h2>Introduction</h2>
              <p>
                Vous cherchez le {config.product.toLowerCase()} idéal ? Vous êtes au bon endroit. Dans ce guide complet, nous analysons en profondeur le {config.product.toLowerCase()} pour vous aider à prendre une décision éclairée.
              </p>
              <p>
                Après des semaines de tests et d'analyses, voici notre verdict complet avec tous les détails que vous devez connaître avant d'acheter.
              </p>
            </div>
          </section>

          <!-- 3. Rich Text — H2 #2: Composition -->
          <section id="composition" class="content-section">
            <div class="rich-text">
              <h2>Composition & Ingrédients</h2>
              <p>
                La composition du Lorem Supplement est l'un de ses principaux atouts. Voici les ingrédients clés qui font la différence :
              </p>
              <p>
                Chaque ingrédient est dosé de manière optimale selon les études scientifiques les plus récentes. La formulation est 100% naturelle, sans additifs ni conservateurs artificiels.
              </p>
              <ul>
                <li><strong>Vitamines B complexe</strong> — Pour l'énergie et le métabolisme</li>
                <li><strong>Zinc</strong> — Soutien immunitaire et antioxydant naturel</li>
                <li><strong>Magnésium</strong> — Réduction de la fatigue et du stress</li>
                <li><strong>Extraits de plantes</strong> — Formule exclusive brevetée</li>
              </ul>
            </div>
          </section>

          <!-- 4. Image Block -->
          <ImageBlock
            src="/banner-placeholder.jpg"
            alt="Photo produit"
            caption="Le Lorem Supplement en conditionnement d'origine."
          />

          <!-- 5. Table of Contents -->
          <TableOfContents items={config.tocItems} />

          <!-- 6. ReviewPromoCard — Produit principal -->
          <ReviewPromoCard product={{
            name: topProduct.name,
            image: topProduct.image,
            rating: topProduct.rating,
            productType: topProduct.productType,
            origin: topProduct.origin,
            availability: topProduct.availability,
            promoCode: topProduct.promoCode,
            promoPercent: topProduct.promoPercent,
            originalPrice: topProduct.originalPrice,
            discountPrice: topProduct.discountPrice,
            affiliateLink: topProduct.affiliateLink,
          }} />

          <!-- 7. Efficacité -->
          <section id="efficacite" class="content-section">
            <div class="rich-text">
              <h2>Efficacité & Résultats</h2>
              <p>
                D'après notre test de 4 semaines et les retours de plus de 2 000 utilisateurs, les résultats sont convaincants :
              </p>
              <ul>
                <li><strong>Semaine 1-2</strong> — Premiers effets sur l'énergie et le bien-être général</li>
                <li><strong>Semaine 3-4</strong> — Résultats visibles sur les objectifs principaux</li>
                <li><strong>Semaine 8+</strong> — Effets optimaux avec une cure continue</li>
              </ul>
              <p>
                Note globale : <strong>8.7/10</strong> — Un des meilleurs scores de notre comparatif.
              </p>
            </div>
          </section>

          <!-- 8. Inner Note (highlight box — bg #f4f2ec) -->
          <InnerNote
            emoji="📌"
            text="Pour des résultats optimaux, nous recommandons une cure d'au moins 8 semaines. N'oubliez pas d'utiliser le code promo <strong>LMC</strong> pour bénéficier de -10% sur votre commande."
          />

          <!-- 9. Prix -->
          <section id="prix" class="content-section">
            <div class="rich-text">
              <h2>Prix & Offres</h2>
              <p>
                Le Lorem Supplement est positionné dans le segment premium du marché. Voici les différentes offres disponibles :
              </p>
              <ul>
                <li><strong>1 boîte</strong> — 49,90 € au lieu de 69,90 € avec le code LMC</li>
                <li><strong>3 boîtes</strong> — Remise supplémentaire de 10%</li>
                <li><strong>6 boîtes</strong> — Meilleur tarif + livraison gratuite</li>
              </ul>
            </div>
          </section>

          <!-- 10. Inner Note (warning) -->
          <InnerNote
            emoji="⚠️"
            text="La garantie satisfait ou remboursé de 60 jours offre une sécurité supplémentaire. Pensez à activer votre garantie dès réception du colis."
          />

          <!-- 11. Avis Clients -->
          <section id="avis" class="content-section">
            <div class="rich-text">
              <h2>Avis Clients</h2>
              <p>
                Avec une note moyenne de 4.8/5 sur Trustpilot (plus de 2 300 avis), le Lorem Supplement jouit d'une excellente réputation.
              </p>
              <p>
                Les points les plus appréciés : efficacité, rapidité de livraison, réactivité du service client.
              </p>
            </div>
          </section>

          <!-- 12. Inner Note (check) -->
          <InnerNote
            emoji="✅"
            text="Le Lorem Supplement a été testé et validé par notre équipe. Nous recommandons ce produit sans hésitation."
          />

          <!-- 13. Avantages & Inconvénients -->
          <section id="pros-cons" class="content-section">
            <div class="rich-text">
              <h2>Avantages & Inconvénients</h2>
              <h3>Ce qu'on aime</h3>
              <ul>
                {config.pros.map((pro) => <li>{pro}</li>)}
              </ul>
              <h3>Ce qu'on aime moins</h3>
              <ul>
                {config.cons.map((con) => <li>{con}</li>)}
              </ul>
            </div>
          </section>

          <!-- 14. Comparison Table -->
          <ComparisonTable
            title="Notre classement"
            headers={[
              { label: '#', align: 'center' },
              { label: 'Produit' },
              { label: 'Note', align: 'center' },
              { label: 'Prix' },
              { label: 'Promo' },
            ]}
            rows={[
              { cells: [1, 'Lorem Supplement Pro', '9,8/10', '80,00 $', 'LMC -10%'], highlight: true, badge: 'Top 1' },
              { cells: [2, 'Ipsum Vitality Max', '7,9/10', '49,90 €', '-15%'] },
              { cells: [3, 'Dolor Wellness', '7,2/10', '39,90 €', '-10%'] },
              { cells: [4, 'Sit Amet Booster', '6,5/10', '39,90 €', '—'] },
            ]}
          />

          <!-- 15. Conclusion -->
          <section id="conclusion" class="content-section">
            <div class="rich-text">
              <h2>Conclusion</h2>
              <p>
                Après notre analyse complète, le Lorem Supplement s'impose comme le meilleur choix en 2026. Sa formulation premium, ses résultats prouvés et la garantie de 60 jours en font un investissement sûr.
              </p>
              <p>
                N'oubliez pas d'utiliser le code <strong>LMC</strong> pour profiter de -10% sur votre commande.
              </p>
            </div>
          </section>

          <!-- 16. FAQ -->
          <FaqAccordion items={config.faq} />
        </div>

        <!-- ═══ RIGHT COLUMN (sticky sidebar) ═══ -->
        <div class="sidebar-column">
          <div class="sidebar-sticky">
            <SidebarCTA
              logoSrc={topProduct.brandLogo}
              promoCode={topProduct.promoCode}
              promoPercent={topProduct.promoPercent}
              originalPrice={topProduct.originalPrice}
              discountPrice={topProduct.discountPrice}
              ctaLink={topProduct.affiliateLink}
              heroImage={topProduct.image}
              rating={topProduct.rating}
              reviewCount={topProduct.reviewCount}
            />
          </div>
        </div>

      </div>
    </div>
  </main>

  <!-- Article Grid -->
  <ArticleGrid articles={sampleArticles} />

  <!-- Editorial Criteria -->
  <EditorialCriteria />
</BaseLayout>
