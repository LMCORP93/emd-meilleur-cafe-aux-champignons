---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BlogHero from '@/components/BlogHero.astro';
import FirstReview from '@/components/FirstReview.astro';
import TableOfContents from '@/components/TableOfContents.astro';
import ImageBlock from '@/components/ImageBlock.astro';
import ComparisonTable from '@/components/ComparisonTable.astro';
import ReviewPromoCard from '@/components/ReviewPromoCard.astro';
import InnerNote from '@/components/InnerNote.astro';
import FaqAccordion from '@/components/FaqAccordion.astro';
import SidebarCTA from '@/components/SidebarCTA.astro';
import ArticleGrid from '@/components/ArticleGrid.astro';
import EditorialCriteria from '@/components/EditorialCriteria.astro';
import config from '@/data/site.config';

const topProduct = config.products[0];

const sampleArticles = [
  {
    title: 'Les meilleurs compléments alimentaires en 2026',
    excerpt: 'Notre sélection des produits les plus efficaces pour votre bien-être quotidien.',
    image: '/logo.svg',
    href: '/',
  },
  {
    title: 'Comment choisir un complément de qualité ?',
    excerpt: 'Les critères essentiels pour identifier un produit fiable et efficace.',
    image: '/logo.svg',
    href: '/',
  },
  {
    title: 'Guide complet sur les vitamines essentielles',
    excerpt: 'Tout ce que vous devez savoir sur les vitamines et leurs bienfaits.',
    image: '/logo.svg',
    href: '/',
  },
];
---

<BaseLayout title={config.seo.title} description={config.seo.description} ogImage={config.seo.ogImage}>
  <!-- JSON-LD -->
  <script type="application/ld+json" slot="json-ld" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": config.seo.title,
    "description": config.seo.description,
    "author": {
      "@type": "Person",
      "name": config.author.name,
    },
    "publisher": {
      "@type": "Organization",
      "name": config.siteName,
    },
    "datePublished": "2026-01-15",
    "dateModified": "2026-04-07",
  })} />

  <!-- Blog Hero -->
  <BlogHero
    title={config.seo.title}
    description={config.seo.description}
    author={config.author.name}
    authorAvatar={config.author.avatar}
    date="15 Janvier 2026"
    readingTime="10 min de lecture"
    bannerImage="/banner-placeholder.jpg"
    product={{
      name: topProduct.name,
      image: topProduct.image,
      promoCode: topProduct.promoCode,
      promoPercent: topProduct.promoPercent,
      originalPrice: topProduct.originalPrice,
      discountPrice: topProduct.discountPrice,
      affiliateLink: topProduct.affiliateLink,
    }}
  />

  <main class="padding-section-medium" style="background-color: #ffffff;">
    <div class="container-large padding-global">
      <div class="blog-grid">

        <!-- ═══ LEFT COLUMN (content) ═══ -->
        <div class="content-column">

          <!-- 1. Quick Summary (En bref) -->
          <FirstReview
            tag="En bref"
            heading="Résumé rapide du Lorem Supplement"
            paragraphs={[
              "Le Lorem Supplement est notre coup de cœur pour 2026. Avec une composition naturelle certifiée et des résultats cliniquement prouvés, il se démarque nettement de la concurrence.",
              "Après des semaines de tests, notre verdict est sans appel : excellent rapport qualité-prix grâce à notre code promo exclusif."
            ]}
            assets={config.quickSummary.assets}
            considerations={config.quickSummary.considerations}
            product={{
              brandName: "Mush N Go",
              brandLogoSrc: "/logo-mushngo.svg",
              rating: topProduct.rating,
              reviewLabel: "Meilleur choix 2026",
              ctaText: "En savoir plus",
              ctaLink: topProduct.affiliateLink,
            }}
          />

          <!-- 2. Table of Contents -->
          <TableOfContents items={config.tocItems} />

          <!-- ══════════════════════════════════════════════════════════
               TEMPLATE ELEMENTS — On valide un par un
               ══════════════════════════════════════════════════════════ -->

          <!-- ✅ VALIDÉ — Rich Text -->
          <section id="introduction" class="content-section">
            <div class="rich-text">
              <h2>Introduction</h2>
              <p>Vous cherchez le {config.product.toLowerCase()} idéal ? Vous êtes au bon endroit.</p>
              <p>Après des semaines de tests, voici notre verdict complet.</p>
            </div>
          </section>

          <section id="composition" class="content-section">
            <div class="rich-text">
              <h2>Composition & Ingrédients</h2>
              <p>La composition est l'un de ses principaux atouts.</p>
              <p>Formulation 100% naturelle, sans additifs.</p>
              <ul>
                <li><strong>Vitamines B</strong> — Énergie et métabolisme</li>
                <li><strong>Zinc</strong> — Soutien immunitaire</li>
                <li><strong>Magnésium</strong> — Réduction fatigue</li>
              </ul>
            </div>
          </section>

          <!-- ✅ VALIDÉ — Image Block -->
          <ImageBlock
            src="/banner-placeholder.jpg"
            alt="Photo produit"
            caption="Le Lorem Supplement en conditionnement d'origine."
          />

          <!-- 🔲 À VALIDER — ReviewPromoCard -->
          <ReviewPromoCard product={{
            name: topProduct.name,
            image: topProduct.image,
            rating: topProduct.rating,
            productType: topProduct.productType,
            origin: topProduct.origin,
            availability: topProduct.availability,
            promoCode: topProduct.promoCode,
            promoPercent: topProduct.promoPercent,
            originalPrice: topProduct.originalPrice,
            discountPrice: topProduct.discountPrice,
            affiliateLink: topProduct.affiliateLink,
          }} />

          <!-- 🔲 À VALIDER — InnerNote -->
          <InnerNote
            emoji="📌"
            text="Pour des résultats optimaux, cure de 8 semaines minimum. Code promo <strong>LMC</strong> pour -10%."
          />

          <!-- 🔲 À VALIDER — ComparisonTable -->
          <ComparisonTable
            title="Notre classement"
            headers={[
              { label: '#', align: 'center' },
              { label: 'Produit' },
              { label: 'Note', align: 'center' },
              { label: 'Prix' },
              { label: 'Promo' },
            ]}
            rows={[
              { cells: [1, 'Lorem Supplement Pro', '9,8/10', '80,00 $', 'LMC -10%'], highlight: true, badge: 'Top 1' },
              { cells: [2, 'Ipsum Vitality Max', '7,9/10', '49,90 €', '-15%'] },
              { cells: [3, 'Dolor Wellness', '7,2/10', '39,90 €', '-10%'] },
              { cells: [4, 'Sit Amet Booster', '6,5/10', '39,90 €', '—'] },
            ]}
          />
        </div>

        <!-- ═══ RIGHT COLUMN (sticky sidebar) ═══ -->
        <div class="sidebar-column">
          <div class="sidebar-sticky">
            <SidebarCTA
              logoSrc={topProduct.brandLogo}
              promoCode={topProduct.promoCode}
              promoPercent={topProduct.promoPercent}
              originalPrice={topProduct.originalPrice}
              discountPrice={topProduct.discountPrice}
              ctaLink={topProduct.affiliateLink}
              heroImage={topProduct.image}
              rating={topProduct.rating}
              reviewCount={topProduct.reviewCount}
            />
          </div>
        </div>

      </div>
    </div>
  </main>

  <!-- Article Grid -->
  <ArticleGrid articles={sampleArticles} />

  <!-- Editorial Criteria -->
  <EditorialCriteria />
</BaseLayout>
