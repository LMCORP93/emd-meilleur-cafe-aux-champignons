---
import '@/styles/global.css';
import Navbar from '@/components/Navbar.astro';
import Footer from '@/components/Footer.astro';
import BrandPopup from '@/components/BrandPopup.astro';
import config from '@/data/site.config';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = config.seo.title,
  description = config.seo.description,
  ogImage = config.seo.ogImage,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <link rel="canonical" href={Astro.url.href} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${config.domain}${ogImage}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:type" content="article" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content={config.siteName} />
    <meta property="og:url" content={Astro.url.href} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${config.domain}${ogImage}`} />
    <meta name="twitter:image:alt" content={title} />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=PT+Sans:ital,wght@0,400;0,700;1,400;1,700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>

    <!-- JSON-LD slot -->
    <slot name="json-ld" />

    <!-- GTAG placeholder -->
    <!-- <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XXXXXXXXXX');
    </script> -->
  </head>
  <body>
    <Navbar
      siteName={config.siteName}
      logoSrc="/logo.svg"
      navLinks={[
        { label: 'Comparatif', href: '/comparatif' },
        { label: 'Blog', href: '/' },
      ]}
      ctaText="Acheter"
      ctaLink={config.products[0].affiliateLink}
    />

    <slot />

    <BrandPopup
      brand={config.products[0].brand}
      productImage={config.products[0].image}
      productName={config.products[0].name}
      productType={config.products[0].productType}
      description={config.products[0].description}
      promoCode={config.products[0].promoCode}
      promoPercent={config.products[0].promoPercent}
      originalPrice={config.products[0].originalPrice}
      discountPrice={config.products[0].discountPrice}
      affiliateLink={config.products[0].affiliateLink}
      rating={config.products[0].rating}
    />

    <Footer
      siteName={config.siteName}
      logoSrc="/logo.svg"
      navLinks={[
        { label: 'Accueil', href: '/' },
        { label: 'Comparatif', href: '/comparatif' },
        { label: 'Blog', href: '/' },
      ]}
      copyright="© 2026 Tout droits réservés - Les avis de Tim"
    />
  </body>
</html>
