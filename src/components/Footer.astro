---
interface NavLink {
  label: string;
  href: string;
}

interface FooterColumn {
  title: string;
  links: NavLink[];
}

interface Props {
  siteName: string;
  logoSrc: string;
  navLinks?: NavLink[];
  copyright: string;
  columns?: FooterColumn[];
  year?: number;
}

const {
  siteName,
  logoSrc,
  navLinks = [],
  copyright,
  columns,
  year = new Date().getFullYear(),
} = Astro.props;

// Blog guide links (placeholder for future articles)
const guideLinks: NavLink[] = [
  // { label: 'Guide des compléments alimentaires', href: '/guides/complements-alimentaires' },
  // { label: 'Bienfaits des adaptogènes', href: '/guides/adaptogenes' },
  // { label: 'Comparatif des cafés fonctionnels', href: '/guides/cafes-fonctionnels' },
];

// Legal / information links
const infoLinks: NavLink[] = [
  { label: 'Politique de confidentialité', href: '/politique-de-confidentialite' },
  { label: 'Mentions légales', href: '/mentions-legales' },
  { label: 'Contact', href: '/contact' },
];
---

<footer class="footer">
  <div class="footer_container">
    <!-- 3-column grid -->
    <div class="footer_grid">

      <!-- Column 1: Logo only -->
      <div class="footer_colonne footer_colonne--logo">
        <a href="/" class="footer_logo-link">
          <img src={logoSrc} alt={siteName} class="footer_logo" />
        </a>
      </div>

      <!-- Column 2: Nos Guides -->
      <div class="footer_colonne">
        <div class="footer_col-title">Nos Guides</div>
        <div class="footer_wrapper-links">
          {guideLinks.length > 0 ? guideLinks.map((link) => (
            <a href={link.href} class="footer_link">
              {link.label}
            </a>
          )) : (
            <span class="footer_link--placeholder">Bientôt disponible…</span>
          )}
        </div>
      </div>

      <!-- Column 3: Informations -->
      <div class="footer_colonne">
        <div class="footer_col-title">Informations</div>
        <div class="footer_wrapper-links">
          {infoLinks.map((link) => (
            <a href={link.href} class="footer_link">
              {link.label}
            </a>
          ))}
        </div>
      </div>

    </div>

    <!-- Bottom sub-footer: copyright -->
    <div class="footer_sub">
      <p class="footer_copyright">© {year} {copyright}</p>
    </div>
  </div>
</footer>

<style>
  /* ── Footer root ── */
  .footer {
    background-color: #f4f2ec;
    color: #242424;
    padding: 3rem 1.5rem 2rem;
  }

  /* ── Container ── */
  .footer_container {
    max-width: 72rem;
    margin-left: auto;
    margin-right: auto;
  }

  /* ── 3-column grid ── */
  .footer_grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 2rem;
  }

  /* ── Column ── */
  .footer_colonne {
    display: flex;
    flex-flow: column;
    justify-content: flex-start;
    align-items: center;
    gap: 1rem;
    text-align: center;
    align-self: start;
  }

  .footer_colonne--logo {
    align-items: flex-start;
    gap: 0.75rem;
  }

  /* ── Logo link ── */
  .footer_logo-link {
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .footer_logo {
    width: 8rem;
    height: 8rem;
    object-fit: contain;
  }

  @media (max-width: 767px) {
    .footer_logo {
      width: 9rem;
      height: 9rem;
    }
  }

  /* ── Column title ── */
  .footer_col-title {
    font-family: 'Archivo', sans-serif;
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #242424;
    opacity: 1;
  }

  /* ── Links wrapper ── */
  .footer_wrapper-links {
    display: flex;
    flex-flow: column;
    gap: 0.5rem;
  }

  /* ── Link ── */
  .footer_link {
    color: #333;
    font-size: 14px;
    text-decoration: none;
    opacity: 0.7;
    transition: opacity 0.2s;
  }
  .footer_link:hover {
    opacity: 0.7;
    color: #ef7a1a;
  }

  .footer_link--placeholder {
    font-size: 14px;
    color: #999;
    font-style: italic;
  }

  /* ── Sub footer ── */
  .footer_sub {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(0, 0, 0, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
  }

  .footer_copyright {
    margin: 0;
    font-size: 12px;
    color: #555;
    opacity: 0.6;
  }

  /* ── Responsive: tablet (≤991px) → 2 columns ── */
  @media (max-width: 991px) {
    .footer_grid {
      grid-template-columns: 1fr 1fr;
    }
    .footer_colonne:last-child {
      grid-column: 1 / -1;
    }
  }

  /* ── Responsive: mobile (≤767px) → flex column ── */
  @media (max-width: 767px) {
    .footer_grid {
      display: flex;
      flex-direction: column;
    }

    .footer_colonne {
      text-align: left;
      justify-content: flex-start;
      align-items: flex-start;
    }

    .footer_colonne--logo {
      align-items: center;
    }

    .footer_sub {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
