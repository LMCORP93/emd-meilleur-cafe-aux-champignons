---
interface NavLink {
  label: string;
  href: string;
}

interface Props {
  siteName: string;
  logoSrc: string;
  navLinks: NavLink[];
  copyright: string;
}

const { siteName, logoSrc, navLinks, copyright } = Astro.props;
---

<footer class="footer-section">
  <!-- Curve divider at top — white curves down into beige footer -->
  <div class="footer-curve-top">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,0 L1440,0 L1440,40 Q720,80 0,40 Z" fill="#f4f2ec"/>
    </svg>
  </div>

  <!-- Main footer content -->
  <div class="footer-content">
    <div class="footer-inner" style="max-width: 72rem;">
      <div class="padding-global">

        <!-- Nav links grid (horizontal row like Webflow) -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class="text-text-grey hover:text-text-dark text-sm font-medium transition-colors duration-200 py-1"
            >
              {link.label}
            </a>
          ))}
        </div>

        <!-- Bottom sub-footer: logo + copyright + legal links -->
        <div class="flex flex-col sm:flex-row items-center gap-4 pt-6 border-t border-black/10">
          <a href="/" class="flex-shrink-0">
            <img
              src={logoSrc}
              alt={siteName}
              class="h-8 w-auto"
              width="32"
              height="32"
            />
          </a>
          <p class="text-text-grey text-xs text-center sm:text-left">
            {copyright}
          </p>
          <div class="flex items-center gap-4 sm:ml-auto">
            <a href="/politique-de-confidentialite" class="text-text-grey hover:text-text-dark text-xs transition-colors duration-200">
              Politique de confidentialité
            </a>
            <a href="/mentions-legales" class="text-text-grey hover:text-text-dark text-xs transition-colors duration-200">
              Mentions légales
            </a>
            <a href="/contact" class="text-text-grey hover:text-text-dark text-xs transition-colors duration-200">
              Contact
            </a>
          </div>
        </div>

      </div>
    </div>
  </div>
</footer>

<style>
  .footer-section {
    position: relative;
    background-color: #f4f2ec;
  }
  .footer-curve-top {
    width: 100%;
    height: 4rem;
    background-color: #ffffff;
  }
  .footer-curve-top svg {
    display: block;
    width: 100%;
    height: 100%;
  }
  .footer-content {
    padding-top: 0;
    padding-bottom: 2.5rem;
  }
  .footer-inner {
    margin-left: auto;
    margin-right: auto;
  }
</style>
