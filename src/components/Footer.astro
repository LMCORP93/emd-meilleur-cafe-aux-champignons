---
interface NavLink {
  label: string;
  href: string;
}

interface FooterColumn {
  title: string;
  links: NavLink[];
}

interface Props {
  siteName: string;
  logoSrc: string;
  navLinks?: NavLink[];
  copyright: string;
  columns?: FooterColumn[];
  year?: number;
}

const {
  siteName,
  logoSrc,
  navLinks = [],
  copyright,
  columns,
  year = new Date().getFullYear(),
} = Astro.props;

// Build columns: if explicit columns are provided, use them.
// Otherwise auto-generate from navLinks (split into 3 cols for cols 2–4).
let footerColumns: FooterColumn[];

if (columns && columns.length > 0) {
  footerColumns = columns;
} else if (navLinks.length > 0) {
  // Distribute navLinks across 3 columns
  const colCount = 3;
  const perCol = Math.ceil(navLinks.length / colCount);
  footerColumns = Array.from({ length: colCount }, (_, i) => ({
    title: i === 0 ? 'Navigation' : i === 1 ? 'Liens' : 'Plus',
    links: navLinks.slice(i * perCol, (i + 1) * perCol),
  }));
} else {
  footerColumns = [
    { title: 'Navigation', links: [] },
    { title: 'Liens', links: [] },
    { title: 'Plus', links: [] },
  ];
}

// Legal links (static, always present)
const legalLinks = [
  { label: 'Politique de confidentialité', href: '/politique-de-confidentialite' },
  { label: 'Mentions légales', href: '/mentions-legales' },
  { label: 'Contact', href: '/contact' },
];
---

<footer class="footer">
  <div class="footer_container">
    <!-- 4-column grid -->
    <div class="footer_grid">

      <!-- Column 1: Logo + site name -->
      <div class="footer_colonne">
        <a href="/" class="footer_logo-link">
          <img src={logoSrc} alt={siteName} class="footer_logo" width="40" height="40" />
          <span class="footer_site-name">{siteName}</span>
        </a>
      </div>

      <!-- Columns 2–4: Navigation link groups -->
      {footerColumns.map((col) => (
        <div class="footer_colonne">
          <div class="footer_col-title">{col.title}</div>
          <div class="footer_wrapper-links">
            {col.links.map((link) => (
              <a href={link.href} class="footer_link">
                {link.label}
              </a>
            ))}
          </div>
        </div>
      ))}

    </div>

    <!-- Bottom sub-footer: copyright + legal links -->
    <div class="footer_sub">
      <p class="footer_copyright">{copyright}</p>
      <div class="footer_legal">
        {legalLinks.map((link) => (
          <a href={link.href} class="footer_link footer_link--legal">
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>

<style>
  /* ── Footer root ── */
  .footer {
    background-color: #222;
    color: #fff;
    padding: 3rem 1.5rem 2rem;
  }

  /* ── Container ── */
  .footer_container {
    max-width: 72rem;
    margin-left: auto;
    margin-right: auto;
  }

  /* ── 4-column grid ── */
  .footer_grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    gap: 1rem;
  }

  /* ── Column ── */
  .footer_colonne {
    display: flex;
    flex-flow: column;
    justify-content: flex-start;
    align-items: center;
    gap: 1rem;
    text-align: center;
  }

  /* ── Logo link ── */
  .footer_logo-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
  }

  .footer_logo {
    width: 2.5rem;
    height: 2.5rem;
    object-fit: contain;
  }

  .footer_site-name {
    font-size: 1.125rem;
    font-weight: 600;
    color: #fff;
  }

  /* ── Column title ── */
  .footer_col-title {
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #fff;
    opacity: 1;
  }

  /* ── Links wrapper ── */
  .footer_wrapper-links {
    display: flex;
    flex-flow: column;
    gap: 0.5rem;
  }

  /* ── Link ── */
  .footer_link {
    color: #fff;
    font-size: 14px;
    text-decoration: none;
    opacity: 0.8;
    transition: opacity 0.2s;
  }
  .footer_link:hover {
    opacity: 1;
  }

  /* ── Sub footer ── */
  .footer_sub {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.15);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .footer_copyright {
    margin: 0;
    font-size: 12px;
    color: #fff;
    opacity: 0.5;
  }

  .footer_legal {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .footer_link--legal {
    font-size: 12px;
    opacity: 0.5;
  }
  .footer_link--legal:hover {
    opacity: 0.8;
  }

  /* ── Responsive: tablet (≤991px) → 2 columns ── */
  @media (max-width: 991px) {
    .footer_grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  /* ── Responsive: mobile (≤767px) → flex column ── */
  @media (max-width: 767px) {
    .footer_grid {
      display: flex;
      flex-direction: column;
    }

    .footer_colonne {
      text-align: left;
      justify-content: flex-start;
      align-items: flex-start;
    }

    .footer_sub {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
