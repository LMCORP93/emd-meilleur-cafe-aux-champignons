---
interface NavLink {
  label: string;
  href: string;
}

interface Props {
  siteName: string;
  logoSrc: string;
  navLinks: NavLink[];
  copyright: string;
}

const { siteName, logoSrc, navLinks, copyright } = Astro.props;

// Legal links (static, always present)
const legalLinks = [
  { label: 'Politique de confidentialité', href: '/politique-de-confidentialite' },
  { label: 'Mentions légales', href: '/mentions-legales' },
  { label: 'Contact', href: '/contact' },
];
---

<footer class="footer-section">
  <!-- Curve divider — beige curves UP into white content above -->
  <div class="footer-curve-top" aria-hidden="true">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,60 L1440,60 L1440,30 Q720,0 0,30 Z" fill="#f4f2ec"/>
    </svg>
  </div>

  <!-- Main footer content -->
  <div class="footer-content">
    <div class="footer-inner">
      <div class="padding-global">

        <!-- Logo -->
        <div class="footer-brand">
          <a href="/" class="footer-logo-link">
            <img src={logoSrc} alt={siteName} class="footer-logo" width="40" height="40" />
          </a>
        </div>

        <!-- Navigation links (auto-populated from site pages) -->
        <nav aria-label="Navigation du pied de page">
          <div class="footer-links-grid">
            {navLinks.map((link) => (
              <a href={link.href} class="footer-link">
                {link.label}
              </a>
            ))}
          </div>
        </nav>

        <!-- Bottom sub-footer: copyright + legal links -->
        <div class="footer-bottom">
          <p class="footer-copyright">{copyright}</p>
          <div class="footer-legal">
            {legalLinks.map((link) => (
              <a href={link.href} class="footer-legal-link">
                {link.label}
              </a>
            ))}
          </div>
        </div>

      </div>
    </div>
  </div>
</footer>

<style>
  .footer-section {
    position: relative;
    background-color: #f4f2ec;
  }

  /* ── Curve: white on top, beige below ── */
  .footer-curve-top {
    width: 100%;
    height: 2rem;
    margin-top: -1px;
    background-color: #ffffff;
  }
  @media (min-width: 768px) {
    .footer-curve-top { height: 3rem; }
  }
  .footer-curve-top svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  /* ── Content area ── */
  .footer-content {
    padding-bottom: 2.5rem;
  }
  .footer-inner {
    max-width: 72rem;
    margin-left: auto;
    margin-right: auto;
  }

  /* ── Brand (logo + tagline) ── */
  .footer-brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 2rem;
    padding-top: 1rem;
  }
  .footer-logo-link {
    display: flex;
    flex-shrink: 0;
  }
  .footer-logo {
    height: 2.5rem;
    width: auto;
  }
  .footer-logo-link {
    display: flex;
    flex-shrink: 0;
  }

  /* ── Links grid ── */
  .footer-links-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
  }

  .footer-link {
    font-family: 'Archivo', sans-serif;
    font-weight: 500;
    font-size: clamp(0.8125rem, 0.8rem + 0.1vw, 0.875rem);
    color: #333;
    text-decoration: none;
    padding: 0.25rem 0;
    transition: color 0.2s;
  }
  .footer-link:hover {
    color: #ef7a1a;
  }

  /* ── Bottom bar ── */
  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding-top: 1.5rem;
  }

  .footer-copyright {
    margin: 0;
    font-size: clamp(0.6875rem, 0.675rem + 0.1vw, 0.75rem);
    color: #777;
  }

  .footer-legal {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .footer-legal-link {
    font-size: clamp(0.6875rem, 0.675rem + 0.1vw, 0.75rem);
    color: #777;
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-legal-link:hover {
    color: #242424;
  }

  @media (max-width: 767px) {
    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
    }
    .footer-legal {
      gap: 0.75rem;
    }
  }
</style>
