            </div>
            <div class="flex gap-0.5">
              {Array.from({ length: 5 }).map((_, i) => (
                <svg class:list={['w-3.5 h-3.5', i < review.rating ? 'text-brand-star' : 'text-gray-200']} fill="currentColor" viewBox="0 0 20 20">
