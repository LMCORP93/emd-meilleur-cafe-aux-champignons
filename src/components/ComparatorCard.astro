---
import StarRating from './StarRating.astro';
import PromoCodeButton from './PromoCodeButton.astro';

interface Product {
  rank: number;
  name: string;
  brand: string;
  slug: string;
  image: string;
  brandLogo: string;
  rating: number;
  reviewCount: number;
  promoCode: string;
  promoPercent: number;
  originalPrice: string;
  discountPrice: string;
  affiliateLink: string;
  origin: string;
  availability: string;
  productType: string;
  pros: string[];
  cons: string[];
  description: string;
}

interface Props {
  product: Product;
}

const { product } = Astro.props;

const rankEmoji = product.rank === 1 ? '🏆' : product.rank === 2 ? '🥈' : product.rank === 3 ? '🥉' : '';
const rankLabel = rankEmoji ? `${rankEmoji} TOP ${product.rank}` : `TOP ${product.rank}`;

const accordionId = `accordion-${product.slug}`;
const chevronId = `chevron-${product.slug}`;
---

<div class="comparator-card-wrapper w-full">
  <div class="comparator-card relative bg-white rounded-xl shadow-card overflow-hidden">
    <!-- ─── TOP Badge (absolute) ─── -->
    {product.rank <= 3 && (
      <div class="absolute top-0 right-0 z-20">
        <div class="bg-primary text-white font-heading font-bold text-xs uppercase tracking-wider px-4 py-1.5 rounded-bl-xl">
          {rankLabel}
        </div>
      </div>
    )}

    <!-- ─── Image Section ─── -->
    <div class="relative bg-bg-light px-6 py-8 flex items-center justify-center min-h-[180px]">
      <img
        src={product.image}
        alt={`${product.name} - ${product.brand}`}
        class="w-auto h-auto max-h-[200px] max-w-[200px] object-contain"
        loading="lazy"
      />
      <!-- Brand logo badge – bottom-right -->
      <div class="absolute bottom-3 right-3 bg-white rounded-lg p-1.5 shadow-card">
        <img
          src={product.brandLogo}
          alt={`Logo ${product.brand}`}
          class="w-10 h-10 object-contain"
          loading="lazy"
        />
      </div>
    </div>

    <!-- ─── Content Section ─── -->
    <div class="p-5 md:p-6">
      <!-- Brand name + StarRating -->
      <div class="flex items-center justify-between mb-1">
        <p class="text-text-grey text-xs font-medium uppercase tracking-wide">{product.brand}</p>
        <StarRating rating={product.rating} size="sm" />
      </div>

      <!-- Product name -->
      <h3 class="font-heading font-bold text-text-dark text-h4 leading-snug mb-2">
        {product.name}
      </h3>

      <!-- Trustpilot line -->
      <div class="flex items-center gap-1.5 mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="#00b67a">
          <path d="M17.56 21.56a1 1 0 0 1-.46-.11L12 18.22l-5.1 2.23a1 1 0 0 1-1.37-1.23l.98-5.59L3.29 9.7a1 1 0 0 1 .55-1.7l5.6-.81 2.5-5.08a1 1 0 0 1 1.8 0l2.5 5.08 5.6.81a1 1 0 0 1 .55 1.7l-3.07 2.99.98 5.59a1 1 0 0 1-.94 1.27z"/>
        </svg>
        <span class="text-text-grey text-xs">
          <span class="font-semibold">{product.reviewCount.toLocaleString('fr-FR')}</span> avis
        </span>
        <span class="text-trust-pilot text-xs font-semibold">Trustpilot</span>
      </div>

      <!-- Info grid -->
      <div class="cc-info-grid">
        {product.promoCode && product.promoPercent > 0 && (
          <div class="cc-info-item cc-info-promo">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
            <span><strong>{product.promoCode}</strong> −{product.promoPercent}%</span>
          </div>
        )}
        {product.origin && (
          <div class="cc-info-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
            <span>{product.origin}</span>
          </div>
        )}
        {product.availability && (
          <div class="cc-info-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
            <span>{product.availability}</span>
          </div>
        )}
        {product.productType && (
          <div class="cc-info-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3c-4.97 0-9 3.13-9 7s4.03 7 9 7 9-3.13 9-7-4.03-7-9-7z"/><path d="M9 17v2a3 3 0 0 0 6 0v-2"/><path d="M12 17v5"/></svg>
            <span>{product.productType}</span>
          </div>
        )}
      </div>

      <!-- Price -->
      <div class="flex items-baseline gap-3 mb-5">
        <span class="text-text-grey text-sm line-through">{product.originalPrice}</span>
        <span class="font-heading font-bold text-text-dark text-2xl">{product.discountPrice}</span>
      </div>

      <!-- Buttons row -->
      <div class="flex flex-col sm:flex-row gap-3">
        {product.promoCode && product.promoPercent > 0 && (
          <PromoCodeButton code={product.promoCode} percent={`${product.promoPercent}%`} />
        )}
        <a
          href={product.affiliateLink}
          rel="nofollow sponsored"
          target="_blank"
          class="btn-solid inline-flex items-center justify-center gap-2 flex-1"
        >
          <span>Visiter {product.brand}</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
          </svg>
        </a>
      </div>

      <!-- ─── Accordion: En savoir plus ─── -->
      <div class="mt-5 border-t border-border-lighter pt-4">
        <button
          class="accordion-trigger flex items-center justify-between w-full text-left py-1 cursor-pointer group"
          data-target={accordionId}
          data-chevron={chevronId}
          aria-expanded="false"
          aria-controls={accordionId}
        >
          <span class="font-heading font-semibold text-sm text-text-dark group-hover:text-primary transition-colors">
            En savoir plus
          </span>
          <svg
            id={chevronId}
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#777"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="accordion-chevron transition-transform duration-300 ease-in-out"
          >
            <path d="m6 9 6 6 6-6" />
          </svg>
        </button>

        <div id={accordionId} class="accordion-content hidden">
          <!-- Description -->
          <div class="mt-3 mb-4">
            <p class="text-sm text-text-body leading-relaxed">{product.description}</p>
          </div>

          <!-- Pros / Cons 2-col grid -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <!-- Points forts -->
            <div class="rounded-lg p-4" style="background-color: #cef5ca;">
              <h6 class="flex items-center gap-2 font-heading font-semibold text-sm mb-3" style="color: #114e0b;">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#114e0b" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><path d="m9 11 3 3L22 4" />
                </svg>
                Points forts
              </h6>
              <ul class="space-y-1.5">
                {product.pros.map((pro) => (
                  <li class="flex items-start gap-2 text-sm" style="color: #114e0b;">
                    <span class="mt-px flex-shrink-0">✓</span>
                    <span>{pro}</span>
                  </li>
                ))}
              </ul>
            </div>

            <!-- À améliorer -->
            <div class="rounded-lg p-4" style="background-color: #fcf8d8;">
              <h6 class="flex items-center gap-2 font-heading font-semibold text-sm mb-3" style="color: #5e5515;">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#5e5515" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10" /><path d="m15 9-6 6" /><path d="m9 9 6 6" />
                </svg>
                À améliorer
              </h6>
              <ul class="space-y-1.5">
                {product.cons.map((con) => (
                  <li class="flex items-start gap-2 text-sm" style="color: #5e5515;">
                    <span class="mt-px flex-shrink-0">⚠</span>
                    <span>{con}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function initComparatorAccordions() {
    document.querySelectorAll('.accordion-trigger').forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const targetId = trigger.getAttribute('data-target');
        const chevronId = trigger.getAttribute('data-chevron');
        if (!targetId) return;

        const content = document.getElementById(targetId);
        if (!content) return;

        const isHidden = content.classList.contains('hidden');
        content.classList.toggle('hidden');

        // Rotate chevron 180deg
        if (chevronId) {
          const chevron = document.getElementById(chevronId);
          if (chevron) {
            chevron.style.transform = isHidden ? 'rotate(180deg)' : 'rotate(0deg)';
          }
        }

        // Update aria
        trigger.setAttribute('aria-expanded', isHidden ? 'true' : 'false');
      });
    });
  }

  // Run on initial load and on Astro view transitions
  initComparatorAccordions();
  document.addEventListener('astro:page-load', initComparatorAccordions);
</script>

<style>
  .comparator-card:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
  }

  /* ── Info grid ── */
  .cc-info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }
  @media (max-width: 479px) {
    .cc-info-grid {
      grid-template-columns: 1fr;
    }
  }

  .cc-info-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8125rem;
    color: #555;
    padding: 0.375rem 0.625rem;
    background: #f8f7f5;
    border-radius: 0.375rem;
    border: 1px solid #e0e0e0;
    line-height: 1.3;
  }
  .cc-info-item svg {
    flex-shrink: 0;
    color: #777;
  }
  .cc-info-promo {
    background: rgba(239, 122, 26, 0.08);
    border-color: rgba(239, 122, 26, 0.2);
    color: #ef7a1a;
    font-weight: 600;
  }
  .cc-info-promo svg {
    color: #ef7a1a;
  }

  .accordion-content:not(.hidden) {
    animation: accordionOpen 0.3s ease-out;
  }

  @keyframes accordionOpen {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
