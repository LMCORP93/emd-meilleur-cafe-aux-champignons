---
interface TocItem {
  id: string;
  label: string;
}

interface Props {
  items: TocItem[];
}

const { items } = Astro.props;
---

<div class="toc-card">
  <!-- Header -->
  <button class="toc-header" id="toc-trigger">
    <span class="toc-title">Sommaire</span>
    <svg class="toc-chevron" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#777" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="m6 9 6 6 6-6" />
    </svg>
  </button>

  <!-- Content -->
  <div class="toc-content" id="toc-content">
    <div class="toc-list">
      {items.map((item, i) => (
        <a
          href={`#${item.id}`}
          class="toc-item"
          onclick={`event.preventDefault(); document.querySelector('#${item.id}')?.scrollIntoView({behavior:'smooth'});`}
        >
          <!-- Timeline dot + connector -->
          <div class="toc-timeline">
            <div class={`toc-dot ${i === 0 ? 'toc-dot-active' : ''}`}></div>
            {i < items.length - 1 && (
              <div class={`toc-connector ${i === 0 ? 'toc-connector-active' : ''}`}></div>
            )}
          </div>
          <!-- Label -->
          <span class={`toc-label ${i === 0 ? 'toc-label-active' : ''}`}>{item.label}</span>
        </a>
      ))}
    </div>
  </div>
</div>

<script>
  function initTocAccordion() {
    const trigger = document.getElementById('toc-trigger');
    if (!trigger) return;
    const content = document.getElementById('toc-content');
    const chevron = trigger.querySelector('.toc-chevron');
    if (!content || !chevron) return;

    trigger.addEventListener('click', () => {
      const isHidden = content.classList.contains('toc-hidden');
      content.classList.toggle('toc-hidden');
      chevron.classList.toggle('toc-chevron-up', !isHidden);
    });
  }
  initTocAccordion();
</script>

<style>
  .toc-card {
    background: #ffffff;
    border: 1px solid #e0e0e0;
    border-radius: 1rem;
    overflow: hidden;
    margin-bottom: 2rem;
  }

  /* Header */
  .toc-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 1rem 1.25rem;
    cursor: pointer;
    border: none;
    background: none;
  }
  .toc-title {
    font-family: 'Archivo', sans-serif;
    font-weight: 700;
    font-size: clamp(1.125rem, 1rem + 0.6vw, 1.375rem);
    color: #242424;
    margin: 0;
    line-height: 1.3;
  }
  .toc-chevron {
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }
  .toc-chevron.toc-chevron-up {
    transform: rotate(180deg);
  }

  /* Content */
  .toc-content {
    padding: 0 1.25rem 1.25rem;
    transition: all 0.2s ease;
  }
  .toc-content.toc-hidden {
    display: none;
  }

  .toc-list {
    display: flex;
    flex-direction: column;
  }

  .toc-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    text-decoration: none;
    transition: color 0.2s;
  }
  .toc-item:hover .toc-label {
    color: #ef7a1a;
  }

  /* Timeline */
  .toc-timeline {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    padding-top: 0.3rem;
  }
  .toc-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: #ffffff;
    border: 1.5px solid #e0e0e0;
    flex-shrink: 0;
  }
  .toc-dot-active {
    background: #ef7a1a;
    border-color: #ef7a1a;
  }
  .toc-connector {
    width: 0;
    height: 1rem;
    border-left: 1px dashed #e0e0e0;
    margin-top: 0.25rem;
  }
  .toc-connector-active {
    border-left: 1px solid #ef7a1a;
  }

  /* Label */
  .toc-label {
    font-size: clamp(0.8125rem, 0.8rem + 0.1vw, 0.875rem);
    color: #333;
    line-height: 1.4;
    transition: color 0.2s;
  }
  .toc-label-active {
    color: #242424;
    font-weight: 600;
  }
</style>
