---
import ReviewTag from './ReviewTag.astro';
import BrandReviewCard from './BrandReviewCard.astro';

interface Props {
  tag: string;
  heading: string;
  paragraphs: string[];
  assets: string[];
  considerations: string[];
  product: {
    brandName: string;
    brandLogoSrc: string;
    rating: number;
    reviewLabel: string;
    ctaText: string;
    ctaLink: string;
  };
}

const { tag, heading, paragraphs, assets, considerations, product } = Astro.props;
---

<section id="quick-summary" class="quick-summary-section">
  <div class="quick-summary-inner">
    <!-- Tag pill -->
    <div class="quick-summary-tag">
      <ReviewTag emoji="📋" text={tag} variant="summary" />
    </div>

    <!-- 2-column grid: Left content / Right card -->
    <div class="quick-summary-grid">
      <!-- LEFT: heading + text + pros/cons -->
      <div class="quick-summary-content">
        <h2 class="quick-summary-heading">
          {heading}
        </h2>

        <!-- Rich text paragraphs -->
        <div class="quick-summary-body">
          {paragraphs.map((p) => (
            <p>{p}</p>
          ))}
        </div>

        <!-- Pros + Cons grid (2 columns) -->
        <div class="quick-summary-proscons-grid">
          <!-- Pros (left) -->
          <div class="quick-summary-list">
            <h4 class="quick-summary-list-title">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#00b67a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10" />
                <path d="m9 12 2 2 4-4" />
              </svg>
              Les principaux atouts
            </h4>
            <ul class="quick-summary-items">
              {assets.map((item) => (
                <li>
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#00b67a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5" /></svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Cons (right) -->
          <div class="quick-summary-list">
            <h4 class="quick-summary-list-title">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef7a1a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3" />
                <path d="M12 9v4" />
                <path d="M12 17h.01" />
              </svg>
              Points à considérer
            </h4>
            <ul class="quick-summary-items">
              {considerations.map((item) => (
                <li>
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ef7a1a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 9-6 6" /><path d="m9 9 6 6" /></svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>

      <!-- RIGHT: Brand review card -->
      <div class="quick-summary-card-col">
        <BrandReviewCard
          brandName={product.brandName}
          brandLogoSrc={product.brandLogoSrc}
          rating={product.rating}
          reviewLabel={product.reviewLabel}
          ctaText={product.ctaText}
          ctaLink={product.ctaLink}
        />
      </div>
    </div>
  </div>
</section>

<style>
  .quick-summary-section {
    background-color: #f4f2ec;
    border-radius: 1rem;
    padding: 1.25rem;
    margin-bottom: 2rem;
    box-shadow: none;
  }
  @media (min-width: 768px) {
    .quick-summary-section { padding: 2rem; }
  }

  .quick-summary-inner {
    max-width: 100%;
  }

  .quick-summary-tag {
    margin-bottom: 1.25rem;
  }

  /* 2-column grid */
  .quick-summary-grid {
    display: grid;
    grid-template-columns: 3fr 1.5fr;
    gap: 2rem;
    align-items: start;
  }
  @media (max-width: 767px) {
    .quick-summary-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Left content */
  .quick-summary-content {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .quick-summary-heading {
    font-family: 'Archivo', sans-serif;
    font-weight: 700;
    font-size: clamp(1.375rem, 1.15rem + 1.1vw, 1.75rem);
    color: #242424;
    margin: 0;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .quick-summary-body {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .quick-summary-body p {
    font-size: clamp(0.9375rem, 0.9rem + 0.2vw, 1rem);
    color: #555;
    line-height: 1.6;
    margin: 0;
  }

  /* Lists (no background) */
  .quick-summary-list {
    margin: 0;
  }

  /* Pros/Cons 2-column grid */
  .quick-summary-proscons-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-top: 0.5rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }
  @media (max-width: 767px) {
    .quick-summary-proscons-grid {
      grid-template-columns: 1fr;
    }
  }
  .quick-summary-list-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Archivo', sans-serif;
    font-weight: 700;
    font-size: clamp(0.9375rem, 0.9rem + 0.2vw, 1rem);
    color: #242424;
    margin: 0 0 0.75rem;
  }
  .quick-summary-items {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .quick-summary-items li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: clamp(0.8125rem, 0.8rem + 0.1vw, 0.875rem);
    color: #333;
    line-height: 1.5;
  }
  .quick-summary-items li svg {
    flex-shrink: 0;
    margin-top: 0.125rem;
  }

  /* Right card column */
  .quick-summary-card-col {
    display: flex;
    justify-content: flex-end;
    position: sticky;
    top: 6rem;
    align-self: start;
  }
  @media (max-width: 767px) {
    .quick-summary-card-col {
      justify-content: stretch;
    }
  }
</style>
