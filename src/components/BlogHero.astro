---
import PromoCodeButton from './PromoCodeButton.astro';

interface HeroProduct {
  name: string;
  image: string;
  promoCode: string;
  promoPercent: number;
  originalPrice: string;
  discountPrice: string;
  affiliateLink: string;
}

interface Props {
  title: string;
  description: string;
  author: string;
  authorAvatar: string;
  date: string;
  readingTime: string;
  bannerImage: string;
  product?: HeroProduct;
}

const { title, description, author, authorAvatar, date, readingTime, bannerImage, product } = Astro.props;
---

<section class="hero-blog-gradient relative overflow-hidden text-white">
  <!-- Decorative circles (positioned by global.css .circle._0/._1/._2) -->
  <div class="circle _0"></div>
  <div class="circle _1"></div>
  <div class="circle _2"></div>

  <div class="pt-16 pb-20 md:pt-24 md:pb-28 relative z-10">
    <div class="mx-auto" style="max-width: 1280px;">
      <div class="px-5 md:px-10">

        <!-- H1 title -->
        <h1 class="text-fluid-4xl font-heading font-bold text-white mb-5 leading-tight" style="max-width: 900px;">
          {title}
        </h1>

        <!-- Description text -->
        <p class="text-white/90 text-fluid-lg leading-relaxed mb-8" style="max-width: 900px;">
          {description}
        </p>

        <!-- Author row -->
        <div class="flex flex-wrap items-center gap-5 mb-10">
          <!-- Author avatar + name -->
          <div class="flex items-center gap-2.5">
            <img
              src={authorAvatar}
              alt={author}
              class="w-8 h-8 rounded-full border-2 border-white object-cover"
              width="32"
              height="32"
              loading="eager"
            />
            <span class="text-white/90 text-sm font-medium">Rédigé par {author}</span>
          </div>

          <!-- Calendar icon + date -->
          <span class="flex items-center gap-1.5 text-white/70 text-sm">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/>
            </svg>
            {date}
          </span>

          <!-- Clock icon + reading time -->
          <span class="flex items-center gap-1.5 text-white/70 text-sm">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
            {readingTime}
          </span>
        </div>

        <!-- Banner image -->
        <div class="rounded-xl overflow-hidden shadow-card-promo" style="max-width: 900px;">
          <img
            src={bannerImage}
            alt="Bannière"
            class="w-full h-auto object-cover"
            loading="eager"
          />
        </div>

        <!-- Optional product CTA -->
        {product && (
          <div class="mt-8 bg-white/10 backdrop-blur-sm rounded-xl p-5 md:p-6" style="max-width: 480px;">
            <p class="text-white/80 font-heading font-semibold text-sm mb-1">{product.name}</p>
            <div class="flex items-baseline gap-3 mb-4">
              <span class="text-white/50 line-through text-sm">{product.originalPrice}</span>
              <span class="text-white text-2xl font-heading font-bold">{product.discountPrice}</span>
            </div>
            <div class="flex flex-wrap items-center gap-3">
              {product.promoCode && product.promoPercent > 0 && (
                <PromoCodeButton code={product.promoCode} percent={`${product.promoPercent}%`} />
              )}
              <a
                href={product.affiliateLink}
                rel="nofollow sponsored"
                target="_blank"
                class="inline-flex items-center gap-2 bg-white text-primary hover:bg-white/90 font-heading font-semibold text-sm px-6 py-2.5 rounded-md transition-colors duration-200"
              >
                Acheter maintenant
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                </svg>
              </a>
            </div>
          </div>
        )}

      </div>
    </div>
  </div>

  <!-- Bottom curve divider (white semicircle blending into #f4f2ec page bg) -->
  <div class="curve-mask">
    <div class="curve-circle" style="--curve-color: #f4f2ec;"></div>
  </div>
</section>
