---
import PromoCodeButton from './PromoCodeButton.astro';

interface HeroProduct {
  name: string;
  image: string;
  promoCode: string;
  promoPercent: number;
  originalPrice: string;
  discountPrice: string;
  affiliateLink: string;
}

interface Props {
  title: string;
  description: string;
  author: string;
  authorAvatar: string;
  date: string;
  readingTime: string;
  bannerImage: string;
  breadcrumbs?: { label: string; href: string }[];
  product?: HeroProduct;
}

const { title, description, author, authorAvatar, date, readingTime, bannerImage, breadcrumbs, product } = Astro.props;
---

<!-- Blog Hero — dark (#222) background, white text, review page header -->
<section class="blog_hero">
  <!-- blog_hero-wrapper-title -->
  <div class="blog_hero-wrapper-title">

    <!-- Breadcrumbs (breadcrumb / breadcrumb_link) -->
    {breadcrumbs && breadcrumbs.length > 0 && (
      <nav class="breadcrumb" aria-label="Fil d'Ariane">
        <a href="/" class="breadcrumb_link">Accueil</a>
        {breadcrumbs.map((crumb, i) => (
          <Fragment>
            <span class="text-text-dark/40 text-xs">/</span>
            {i === breadcrumbs.length - 1 ? (
              <span class="breadcrumb_link !no-underline !font-semibold">{crumb.label}</span>
            ) : (
              <a href={crumb.href} class="breadcrumb_link">{crumb.label}</a>
            )}
          </Fragment>
        ))}
      </nav>
    )}

    <!-- H1 Title -->
    <h1 class="text-h1 text-text-dark max-w-[56rem]">{title}</h1>

    <!-- Description -->
    <p class="text-text-dark/80 text-paragraph leading-[1.6] max-w-[45rem]">{description}</p>

    <!-- Price block: compare-at + discount + promo tag -->
    {product && (
      <div class="flex flex-wrap items-baseline gap-2">
        <span class="compare-at-price-text">{product.originalPrice}</span>
        <span class="price-text">{product.discountPrice}</span>
        {product.promoCode && product.promoPercent > 0 && (
          <span class="review_tag">Code : {product.promoCode}</span>
        )}
      </div>
    )}

    <!-- Promo code copy button -->
    {product && product.promoCode && (
      <PromoCodeButton code={product.promoCode} percent={`${product.promoPercent}%`} />
    )}

    <!-- Author info row (hero_wrapper-author) -->
    <div class="hero_wrapper-author">
      <!-- Avatar + Name (hero_wrapper-img-name) -->
      <div class="hero_wrapper-img-name">
        <img
          src={authorAvatar}
          alt={author}
          class="profil-img"
          width="32"
          height="32"
          loading="eager"
        />
        <span class="text-text-dark text-sm">Rédigé par {author}</span>
      </div>

      <!-- Date -->
      <div class="hero_wrapper-img-name">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-text-dark/70 shrink-0">
          <rect width="18" height="18" x="3" y="4" rx="2" ry="2"/>
          <line x1="16" x2="16" y1="2" y2="6"/>
          <line x1="8" x2="8" y1="2" y2="6"/>
          <line x1="3" x2="21" y1="10" y2="10"/>
        </svg>
        <span class="text-text-dark/70 text-sm">{date}</span>
      </div>

      <!-- Reading time -->
      <div class="hero_wrapper-img-name">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-text-dark/70 shrink-0">
          <path d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0a9 9 0 0 1 18 0"/>
        </svg>
        <span class="text-text-dark/70 text-sm">{readingTime}</span>
      </div>
    </div>
  </div>

  <!-- Banner image (blog_img) -->
  {bannerImage && (
    <div class="blog_hero-img-wrapper">
      <img
        src={bannerImage}
        alt="Bannière"
        class="blog_img"
        loading="eager"
      />
    </div>
  )}
</section>

<style>
  /* ── Outer section ─────────────────────────────────── */
  .blog_hero {
    background-color: #f4f2ec;
  }

  /* ── blog_hero-wrapper-title ───────────────────────── */
  .blog_hero-wrapper-title {
    gap: 1.5rem;
    color: #242424;
    text-align: left;
    flex-flow: column;
    justify-content: center;
    align-items: flex-start;
    margin-left: 3.5rem;
    margin-right: 3.5rem;
    padding-top: 3rem;
    padding-bottom: 1.5rem;
    display: flex;
  }
  /* Responsive padding shrink */
  @media (max-width: 991px) {
    .blog_hero-wrapper-title {
      margin-left: 1.5rem;
      margin-right: 1.5rem;
    }
  }
  @media (max-width: 767px) {
    .blog_hero-wrapper-title {
      margin-left: 1.25rem;
      margin-right: 1.25rem;
    }
  }

  /* ── Banner image wrapper ──────────────────────────── */
  .blog_hero-img-wrapper {
    margin-left: 3.5rem;
    margin-right: 3.5rem;
    padding-bottom: 2rem;
  }
  @media (max-width: 991px) {
    .blog_hero-img-wrapper {
      margin-left: 1.5rem;
      margin-right: 1.5rem;
    }
  }
  @media (max-width: 767px) {
    .blog_hero-img-wrapper {
      margin-left: 1.25rem;
      margin-right: 1.25rem;
    }
  }

  /* ── blog_img ──────────────────────────────────────── */
  .blog_img {
    border-radius: 16px;
    width: 100%;
    display: block;
  }

  /* ── hero_wrapper-author ───────────────────────────── */
  .hero_wrapper-author {
    gap: 1rem;
    color: black;
    justify-content: center;
    align-items: center;
    display: flex;
  }
  /* Mobile: flex-column */
  @media (max-width: 767px) {
    .hero_wrapper-author {
      flex-direction: column;
      align-items: flex-start;
      justify-content: flex-start;
    }
  }

  /* ── hero_wrapper-img-name ─────────────────────────── */
  .hero_wrapper-img-name {
    gap: 0.5rem;
    justify-content: flex-start;
    align-items: center;
    display: flex;
  }

  /* ── profil-img ────────────────────────────────────── */
  .profil-img {
    border-radius: 999px;
    width: 32px;
    height: 32px;
    object-fit: cover;
  }

  /* ── compare-at-price-text ─────────────────────────── */
  .compare-at-price-text {
    color: rgba(36, 36, 36, 0.4);
    text-decoration: line-through;
    font-size: 0.875rem;
  }

  /* ── price-text ────────────────────────────────────── */
  .price-text {
    color: #242424;
    font-weight: 700;
    line-height: 1;
    font-size: 1.125rem;
  }

  /* ── review_tag ────────────────────────────────────── */
  .review_tag {
    background-color: #ef7a1a;
    color: #f2f2f2;
    border-radius: 999px;
    padding: 0.25rem 0.5rem;
    font-weight: 600;
    font-size: 0.8125rem;
  }

  /* ── breadcrumb ────────────────────────────────────── */
  .breadcrumb {
    gap: 4px;
    display: flex;
  }
  .breadcrumb_link {
    color: #242424;
    font-size: 12px;
    text-decoration: underline;
  }
  .breadcrumb_link:hover {
    color: #ef7a1a;
  }
</style>
