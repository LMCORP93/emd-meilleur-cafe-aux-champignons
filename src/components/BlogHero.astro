---
import PromoCodeButton from './PromoCodeButton.astro';
import Breadcrumbs from './Breadcrumbs.astro';

interface HeroProduct {
  name: string;
  image: string;
  promoCode: string;
  promoPercent: number;
  originalPrice: string;
  discountPrice: string;
  affiliateLink: string;
}

interface Props {
  title: string;
  description: string;
  author: string;
  authorAvatar: string;
  date: string;
  readingTime: string;
  bannerImage: string;
  breadcrumbs?: { label: string; href: string }[];
  product?: HeroProduct;
}

const { title, description, author, authorAvatar, date, readingTime, bannerImage, breadcrumbs, product } = Astro.props;
---

<section class="hero-section">
  <!-- Decorative circles (top-right, overlapping navbar) -->
  <div class="circle _1"></div>
  <div class="circle _2"></div>

  <div class="hero-content">
    <div class="hero-inner" style="max-width: 72rem;">

      <!-- Breadcrumbs -->
      {breadcrumbs && breadcrumbs.length > 0 && (
        <div class="hero-breadcrumbs">
          <Breadcrumbs items={breadcrumbs} />
        </div>
      )}

      <!-- H1 title -->
      <h1 class="hero-title">
        {title}
      </h1>

      <!-- Description -->
      <p class="hero-description">
        {description}
      </p>

      <!-- CTA text (price row) -->
      {product && (
        <div class="hero-cta-text">
          <span class="hero-cta-label">Price from:</span>
          <span class="compare-at-price-text">{product.originalPrice}</span>
          <span class="hero-cta-price">{product.discountPrice}</span>
          <span class="hero-cta-label">on your first order with the code:</span>
        </div>
      )}

      <!-- Buttons row — side by side -->
      {product && (
        <div class="hero-buttons">
          {product.promoCode && product.promoPercent > 0 && (
            <PromoCodeButton code={product.promoCode} percent={`${product.promoPercent}%`} />
          )}
          <a
            href={product.affiliateLink}
            rel="nofollow sponsored"
            target="_blank"
            class="btn-solid"
          >
            <span>Acheter maintenant</span>
            <span class="hero-shop-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M11.999 1.993c-5.514.001-10 4.487-10 10.001s4.486 10 10.001 10c5.513 0 9.999-4.486 10-10s-4.486-10-10.001-10.001M12 19.994c-4.412 0-8.001-3.589-8.001-8s3.589-8 8-8.001C16.411 3.994 20 7.583 20 11.994c-.001 4.411-3.59 8-8 8"></path>
                <path fill="currentColor" d="M12 10.994H8v2h4V16l4.005-4.005L12 7.991z"></path>
              </svg>
            </span>
          </a>
        </div>
      )}

      <!-- Author row -->
      <div class="hero-author-row">
        <div class="hero-author-item">
          <img
            src={authorAvatar}
            alt={author}
            class="hero-author-avatar"
            width="32"
            height="32"
            loading="eager"
          />
          <span class="hero-author-text">Rédigé par {author}</span>
        </div>
        <div class="hero-author-item">
          <span class="hero-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="m14.363 5.652l1.48-1.48a2 2 0 0 1 2.829 0l1.414 1.414a2 2 0 0 1 0 2.828l-1.48 1.48m-4.243-4.242l-9.616 9.615a2 2 0 0 0-.578 1.238l-.242 2.74a1 1 0 0 0 1.084 1.085l2.74-.242a2 2 0 0 0 1.24-.578l9.615-9.616m-4.243-4.242l4.243 4.242"></path>
            </svg>
          </span>
          <span class="hero-author-text">Publié le {date}</span>
        </div>
        <div class="hero-author-item">
          <span class="hero-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0a9 9 0 0 1 18 0"></path>
            </svg>
          </span>
          <span class="hero-author-text">{readingTime}</span>
        </div>
      </div>

      <!-- Banner image -->
      {bannerImage && (
        <img
          src={bannerImage}
          alt="Bannière"
          class="hero-banner"
          style="max-width: 1024px;"
          loading="eager"
        />
      )}

    </div>
  </div>

  <!-- Bottom curve divider — beige background curves down into white -->
  <div class="hero-curve-bottom">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,0 L0,40 Q720,80 1440,40 L1440,0 Z" fill="#f4f2ec"/>
    </svg>
  </div>
</section>

<style>
  .hero-curve-bottom {
    width: 100%;
    height: 3rem;
    background-color: #ffffff;
    margin-top: 1.5rem;
  }
  @media (min-width: 768px) {
    .hero-curve-bottom { height: 4rem; margin-top: 2rem; }
  }
  .hero-curve-bottom svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  .hero-section {
    position: relative;
    background-color: #f4f2ec;
    z-index: 1;
    padding-top: 1.5rem;
  }
  .hero-content {
    padding-top: 2.5rem;
    padding-bottom: 0;
    position: relative;
    z-index: 1;
  }
  @media (min-width: 768px) {
    .hero-section { padding-top: 3rem; }
    .hero-content { padding-top: 4rem; }
  }
  .hero-inner {
    margin-left: auto;
    margin-right: auto;
    padding-left: 3rem;
    padding-right: 3rem;
  }
  @media (max-width: 991px) {
    .hero-inner { padding-left: 2rem; padding-right: 2rem; }
  }
  @media (max-width: 767px) {
    .hero-inner { padding-left: 1.25rem; padding-right: 1.25rem; }
  }
  @media (max-width: 479px) {
    .hero-inner { padding-left: 1rem; padding-right: 1rem; }
  }

  .hero-breadcrumbs {
    margin-bottom: 1rem;
  }
  @media (min-width: 768px) {
    .hero-breadcrumbs { margin-bottom: 1.5rem; }
  }

  .hero-title {
    font-family: 'Archivo', sans-serif;
    font-weight: 700;
    color: #242424;
    line-height: 1.1;
    letter-spacing: -0.02em;
    max-width: 56rem;
    margin-bottom: 1rem;
  }

  .hero-description {
    color: #595b61;
    line-height: 1.6;
    margin-bottom: 1.5rem;
    max-width: 45rem;
  }
  @media (min-width: 768px) {
    .hero-description { margin-bottom: 2rem; }
  }

  /* CTA text row */
  .hero-cta-text {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }
  .hero-cta-label {
    font-size: 0.8125rem;
    color: #595b61;
  }
  @media (min-width: 768px) {
    .hero-cta-label { font-size: 0.875rem; }
  }
  .hero-cta-price {
    font-family: 'Archivo', sans-serif;
    font-size: clamp(1rem, 0.95rem + 0.25vw, 1.25rem);
    font-weight: 600;
    color: #242424;
  }

  /* Buttons — side by side, same shape */
  .hero-buttons {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  @media (min-width: 768px) {
    .hero-buttons { gap: 1rem; margin-bottom: 2rem; }
  }

  .hero-shop-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.25rem;
    height: 1.25rem;
  }

  /* Author row */
  .hero-author-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  @media (min-width: 768px) {
    .hero-author-row { gap: 1rem; margin-bottom: 2rem; }
  }
  .hero-author-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .hero-author-avatar {
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid white;
  }
  .hero-author-text {
    font-size: 0.8125rem;
    color: #595b61;
  }
  @media (min-width: 768px) {
    .hero-author-text { font-size: 0.875rem; }
  }

  .hero-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1rem;
    height: 1rem;
    color: #595b61;
  }

  /* Banner */
  .hero-banner {
    width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: 12px;
    margin-bottom: 1.5rem;
  }
  @media (min-width: 768px) {
    .hero-banner { border-radius: 16px; margin-bottom: 2rem; }
  }
</style>
