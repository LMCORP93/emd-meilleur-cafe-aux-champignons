---
interface Article {
  title: string;
  excerpt: string;
  image: string;
  href: string;
}

interface Props {
  articles: Article[];
}

const { articles } = Astro.props;
---

<section class="padding-section-small">
  <div class="container-medium padding-global">
    <!-- Section heading with extending line -->
    <div class="flex items-center gap-4 mb-8">
      <h3 class="font-heading font-bold text-text-dark whitespace-nowrap">Dernières actualités</h3>
      <div class="line"></div>
    </div>

    <!-- 3-column responsive grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {articles.map((article) => (
        <a href={article.href} class="card-blog bg-white rounded-xl shadow-card overflow-hidden block group no-underline">
          <div class="aspect-[16/10] overflow-hidden bg-bg-light">
            <img
              src={article.image}
              alt={article.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
          </div>
          <div class="p-4">
            <h6 class="font-heading font-bold text-text-dark mb-2 group-hover:text-primary transition-colors leading-snug">
              {article.title}
            </h6>
            <p class="text-text-grey text-sm line-clamp-2 mb-0">{article.excerpt}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
