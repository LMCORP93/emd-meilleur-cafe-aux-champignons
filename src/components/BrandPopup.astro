---
interface Props {
  brand: string;
  brandLogo: string;
  productImage: string;
  productName: string;
  productType: string;
  description: string;
  promoCode: string;
  promoPercent: number;
  originalPrice: string;
  discountPrice: string;
  affiliateLink: string;
  rating: number;
}

const {
  brand, brandLogo, productImage, productName, productType,
  description, promoCode, promoPercent, originalPrice, discountPrice,
  affiliateLink,
} = Astro.props;

// Truncate description to 2 lines max
const shortDesc = description.length > 120 ? description.slice(0, 117) + '...' : description;
---

<div id="brand-popup" class="brand-popup" role="dialog" aria-modal="true" aria-label="Offre exclusive">
  <div id="popup-overlay" class="brand-popup-overlay"></div>

  <div class="brand-popup-container">
    <div class="brand-popup-card">
      <!-- Close button -->
      <button id="popup-close" class="brand-popup-close" aria-label="Fermer">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#666" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 6 6 18" /><path d="m6 6 12 12" />
        </svg>
      </button>

      <!-- Top: logo + tag inline -->
      <div class="brand-popup-top">
        <img src={brandLogo} alt={`Logo ${brand}`} class="brand-popup-logo" width="100" height="100" />
        <span class="brand-popup-tag">Offre exclusive</span>
      </div>

      <div class="brand-popup-body">
        <!-- Product name -->
        <h3 class="brand-popup-title">{productName}</h3>

        <!-- Description (2 lines max) -->
        <p class="brand-popup-desc">{shortDesc}</p>

        <!-- Product image (square, rounded) -->
        <img src={productImage} alt={productName} class="brand-popup-image" loading="lazy" />

        <!-- Price -->
        <div class="brand-popup-price">
          <span class="brand-popup-price-old">{originalPrice}</span>
          <span class="brand-popup-price-new">{discountPrice}</span>
        </div>

        <!-- Buttons row -->
        {promoCode && promoPercent > 0 && (
          <div class="brand-popup-buttons">
            <!-- Copy promo button -->
            <button
              id="popup-copy-btn"
              class="copy-promo-btn btn-dashed"
              data-code={promoCode}
            >
              <span class="promo-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path fill="currentColor" d="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2m0 16H8V7h11z"></path>
                </svg>
              </span>
              <span class="promo-code-text">{promoCode}</span>
              <span class="promo-percent">-{promoPercent}%</span>
            </button>

            <!-- CTA -->
            <a
              href={affiliateLink}
              rel="nofollow sponsored"
              target="_blank"
              class="btn-solid"
            >
              <span>Acheter maintenant</span>
              <span class="btn-arrow">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </span>
            </a>
          </div>
        )}
      </div>
    </div>
  </div>
</div>

<script>
  function initBrandPopup() {
    const popup = document.getElementById('brand-popup') as HTMLElement | null;
    const overlay = document.getElementById('popup-overlay');
    const closeBtn = document.getElementById('popup-close');
    const copyBtn = document.getElementById('popup-copy-btn') as HTMLElement | null;

    if (!popup) return;

    if (sessionStorage.getItem('emd-brand-popup-shown')) return;

    const timer = setTimeout(() => {
      popup.classList.add('is-open');
      document.body.style.overflow = 'hidden';
      sessionStorage.setItem('emd-brand-popup-shown', 'true');
    }, 7000);

    const closePopup = () => {
      popup.classList.remove('is-open');
      document.body.style.overflow = '';
      clearTimeout(timer);
    };

    if (overlay) overlay.addEventListener('click', closePopup);
    if (closeBtn) closeBtn.addEventListener('click', closePopup);

    const escHandler = (e: KeyboardEvent) => {
      if (e.key === 'Escape' && popup.classList.contains('is-open')) {
        closePopup();
        document.removeEventListener('keydown', escHandler);
      }
    };
    document.addEventListener('keydown', escHandler);

    if (copyBtn) {
      copyBtn.addEventListener('click', () => {
        const code = copyBtn.getAttribute('data-code') || '';
        const textEl = copyBtn.querySelector('.promo-code-text');
        navigator.clipboard.writeText(code).then(() => {
          if (textEl) {
            const original = textEl.textContent || '';
            textEl.textContent = '✓ Copié !';
            textEl.style.color = '#00b67a';
            setTimeout(() => { textEl.textContent = original; textEl.style.color = ''; }, 1500);
          }
        });
      });
    }
  }

  initBrandPopup();
</script>

<style>
  /* ── Popup ── */
  .brand-popup {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }
  .brand-popup.is-open {
    opacity: 1;
    visibility: visible;
  }

  .brand-popup-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
  }

  .brand-popup-container {
    position: relative;
    width: 100%;
    max-width: 380px;
  }

  .brand-popup-card {
    position: relative;
    background: #ffffff;
    border-radius: 0.75rem;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
    overflow: hidden;
  }

  /* ── Close ── */
  .brand-popup-close {
    position: absolute;
    top: 0.625rem;
    right: 0.625rem;
    z-index: 10;
    width: 1.75rem;
    height: 1.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: #f4f4f4;
    border: none;
    cursor: pointer;
    transition: background-color 0.2s;
  }
  .brand-popup-close:hover {
    background: #e0e0e0;
  }

  /* ── Top: logo + tag ── */
  .brand-popup-top {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.625rem;
    padding-top: 1.75rem;
  }
  .brand-popup-logo {
    width: 96px;
    height: 96px;
    object-fit: contain;
  }
  .brand-popup-tag {
    display: inline-block;
    background-color: #ef7a1a;
    color: #fff;
    font-family: 'Archivo', sans-serif;
    font-weight: 700;
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.2rem 0.75rem;
    border-radius: 999px;
  }

  /* ── Body ── */
  .brand-popup-body {
    padding: 1rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    text-align: center;
  }

  /* ── Title ── */
  .brand-popup-title {
    font-family: 'Archivo', sans-serif;
    font-weight: 700;
    font-size: 1.125rem;
    color: #242424;
    margin: 0;
    line-height: 1.3;
  }

  /* ── Description (2 lines) ── */
  .brand-popup-desc {
    font-size: 0.8125rem;
    color: #777;
    line-height: 1.5;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Product image ── */
  .brand-popup-image {
    width: 140px;
    height: 140px;
    object-fit: contain;
    border-radius: 0.5rem;
  }

  /* ── Price ── */
  .brand-popup-price {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }
  .brand-popup-price-old {
    font-size: 0.8125rem;
    color: #999;
    text-decoration: line-through;
  }
  .brand-popup-price-new {
    font-family: 'Archivo', sans-serif;
    font-weight: 800;
    font-size: 1.375rem;
    color: #ef7a1a;
    line-height: 1;
  }

  /* ── Buttons row ── */
  .brand-popup-buttons {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    width: 100%;
    margin-top: 0.25rem;
  }
  @media (max-width: 380px) {
    .brand-popup-buttons {
      flex-direction: column;
    }
    .brand-popup-buttons .btn-solid,
    .brand-popup-buttons .btn-dashed {
      width: 100%;
      justify-content: center;
    }
  }

  .brand-popup-buttons .btn-solid {
    flex: 1;
  }
</style>
