---
interface Props {
  text: string;
  emoji?: string;
}

const { text, emoji = '📌' } = Astro.props;
---

<div class="inner-note">
  <p class="inner-note-text">
    <span class="inner-note-emoji">{emoji}</span>
    <Fragment set:html={text} />
  </p>
</div>

<style>
  .inner-note {
    background-color: #f4f2ec;
    border-radius: 1rem;
    padding: 1.25rem 1.5rem;
    margin-bottom: 1.5rem;
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.12);
  }

  .inner-note-text {
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.625;
    color: #2d2d2d;
  }

  .inner-note-emoji {
    margin-right: 0.5rem;
  }
</style>
