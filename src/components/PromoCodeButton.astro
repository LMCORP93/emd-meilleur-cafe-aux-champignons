---
interface Props {
  code: string;
  percent: string;
}

const { code, percent } = Astro.props;
---

<button
  class="copy-promo-btn promo-code-btn"
  data-code={code}
  data-code-text={code}
  type="button"
>
  <span class="promo-icon">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path fill="currentColor" d="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2m0 16H8V7h11z"></path>
    </svg>
  </span>
  <span class="promo-code-text">{code}</span>
  <span class="promo-percent">-{percent}</span>
</button>

<script>
  function initPromoCopyButtons() {
    document.querySelectorAll('.copy-promo-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const code = (btn as HTMLElement).getAttribute('data-code') || '';
        const textEl = btn.querySelector('.promo-code-text');

        navigator.clipboard.writeText(code).then(() => {
          if (textEl) {
            const original = textEl.textContent || '';
            textEl.textContent = '✓ Copié !';
            textEl.style.color = '#00b67a';
            setTimeout(() => {
              textEl.textContent = original;
              textEl.style.color = '';
            }, 1500);
          }
        });
      });
    });
  }

  initPromoCopyButtons();
</script>

<style>
  .promo-code-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.75rem 1.25rem;
    border: 2px dashed #ef7a1a;
    border-radius: 0.5rem;
    background: transparent;
    color: #ef7a1a;
    cursor: pointer;
    font-family: 'Archivo', sans-serif;
    font-size: 0.9375rem;
    line-height: 1;
    transition: background-color 0.2s, border-color 0.2s;
    white-space: nowrap;
  }
  .promo-code-btn:hover {
    background-color: rgba(239, 122, 26, 0.06);
    border-color: #ff8c2e;
  }
  .promo-code-btn:active {
    background-color: rgba(239, 122, 26, 0.12);
  }
  .promo-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .promo-icon svg {
    width: 16px;
    height: 16px;
  }
  .promo-code-text {
    font-weight: 700;
    color: #242424;
    transition: color 0.2s;
  }
  .promo-percent {
    font-weight: 700;
    color: #ef7a1a;
  }
</style>
