---
interface Props {
  code: string;
  percent: string;
}

const { code, percent } = Astro.props;
---

<div class="inline-block">
  <button
    class="copy-promo-btn inline-flex items-center gap-2 bg-bg-tertiary border border-border-light rounded px-4 py-2 text-sm hover:bg-border-lighter transition-colors cursor-pointer"
    data-code={code}
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#777" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect width="14" height="14" x="8" y="8" rx="2" ry="2" /><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2" />
    </svg>
    <span class="font-mono font-semibold text-text-dark">{code}</span>
    <span class="text-primary font-semibold">-{percent}</span>
  </button>
  <p class="copy-feedback">✓ Code copié !</p>
</div>

<script>
  function initPromoCopyButtons() {
    document.querySelectorAll('.copy-promo-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const code = (btn as HTMLElement).getAttribute('data-code') || '';
        const feedback = btn.nextElementSibling as HTMLElement | null;

        navigator.clipboard.writeText(code).then(() => {
          if (feedback && feedback.classList.contains('copy-feedback')) {
            feedback.classList.add('show');
            setTimeout(() => { feedback.classList.remove('show'); }, 2000);
          }
        });
      });
    });
  }

  initPromoCopyButtons();
</script>
