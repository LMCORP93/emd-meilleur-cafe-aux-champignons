---
interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;
---

<div class="faq-section">
  <h2 class="faq-heading">Questions Fréquentes</h2>

  {items.map((item, i) => (
    <div class="faq-item">
      <button
        class="faq-trigger"
        data-target={`faq-answer-${i}`}
        aria-expanded="false"
        aria-controls={`faq-answer-${i}`}
      >
        <span class="faq-question">{item.question}</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#777" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="faq-chevron" aria-hidden="true">
          <path d="m6 9 6 6 6-6" />
        </svg>
      </button>
      <div id={`faq-answer-${i}`} class="faq-content" role="region" style="max-height: 0; opacity: 0;">
        <div class="faq-answer">
          <p>{item.answer}</p>
        </div>
      </div>
    </div>
  ))}
</div>

<script>
  function initFaq() {
    const triggers = document.querySelectorAll('.faq-trigger');

    triggers.forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const targetId = trigger.getAttribute('data-target');
        if (!targetId) return;

        const target = document.getElementById(targetId);
        if (!target) return;

        const isOpen = target.style.maxHeight && target.style.maxHeight !== '0px';

        // Close all others
        document.querySelectorAll('.faq-content').forEach((content) => {
          content.style.maxHeight = '0px';
          content.style.opacity = '0';
        });
        document.querySelectorAll('.faq-chevron').forEach((chevron) => {
          (chevron as SVGElement).style.transform = 'rotate(0deg)';
        });
        document.querySelectorAll('.faq-trigger').forEach((t) => {
          t.setAttribute('aria-expanded', 'false');
        });

        if (!isOpen) {
          target.style.maxHeight = target.scrollHeight + 'px';
          target.style.opacity = '1';
          const chevron = trigger.querySelector('.faq-chevron');
          if (chevron) {
            (chevron as SVGElement).style.transform = 'rotate(180deg)';
          }
          trigger.setAttribute('aria-expanded', 'true');
        }
      });
    });
  }

  initFaq();
</script>

<style>
  .faq-section {
    width: 100%;
  }

  .faq-heading {
    font-family: 'Archivo', sans-serif;
    font-weight: 700;
    font-size: clamp(1.375rem, 1.15rem + 1.1vw, 1.75rem);
    color: #242424;
    margin: 0 0 1.25rem;
    line-height: 1.2;
  }

  .faq-item {
    border-bottom: 1px solid #e5e5e5;
    padding: 1rem 0;
  }
  .faq-item:first-child {
    padding-top: 0;
  }
  .faq-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .faq-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    text-align: left;
    gap: 1rem;
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
  }

  .faq-question {
    font-family: 'Archivo', sans-serif;
    font-weight: 600;
    font-size: clamp(0.8125rem, 0.8rem + 0.1vw, 0.875rem);
    color: #242424;
    line-height: 1.4;
  }

  .faq-chevron {
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  .faq-content {
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .faq-answer {
    padding-top: 0.75rem;
    font-size: clamp(0.8125rem, 0.8rem + 0.1vw, 0.875rem);
    color: #333;
    line-height: 1.6;
  }
  .faq-answer p {
    margin: 0;
  }
</style>
