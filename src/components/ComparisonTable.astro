---
interface TableHeader {
  label: string;
  align?: 'left' | 'center';
}

interface TableRow {
  cells: (string | number)[];
  highlight?: boolean;
}

interface Props {
  title?: string;
  headers: TableHeader[];
  rows: TableRow[];
}

const { title, headers, rows } = Astro.props;
---

<div class="comparison-table-wrapper">
  {title && <h3 class="comparison-table-title">{title}</h3>}

  <div class="comparison-table-scroll">
    <table class="comparison-table">
      <thead>
        <tr>
          {headers.map((h) => (
            <th class={`comparison-table-th comparison-table-th--${h.align || 'left'}`}>
              {h.label}
            </th>
          ))}
        </tr>
      </thead>
      <tbody>
        {rows.map((row, i) => (
          <tr class={`comparison-table-row ${row.highlight ? 'comparison-table-row--highlight' : ''}`}>
            {row.cells.map((cell, j) => (
              <td class={`comparison-table-td comparison-table-td--${headers[j]?.align || 'left'}`}>
                {cell}
              </td>
            ))}
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>

<style>
  .comparison-table-wrapper {
    margin: 0 0 2rem;
  }

  .comparison-table-title {
    font-family: 'Archivo', sans-serif;
    font-weight: 700;
    font-size: clamp(1.125rem, 1rem + 0.6vw, 1.375rem);
    color: #242424;
    margin: 0 0 1rem;
  }

  .comparison-table-scroll {
    overflow-x: auto;
    border-radius: 1rem;
    border: 1px solid #e0e0e0;
  }

  .comparison-table {
    width: 100%;
    border-collapse: collapse;
    font-size: clamp(0.8125rem, 0.8rem + 0.1vw, 0.875rem);
  }

  .comparison-table-th {
    font-family: 'Archivo', sans-serif;
    font-weight: 700;
    font-size: clamp(0.6875rem, 0.675rem + 0.1vw, 0.75rem);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #777;
    padding: 0.625rem 0.75rem;
    border-bottom: 1px solid #e0e0e0;
    background-color: #f8f8f8;
    white-space: nowrap;
  }
  .comparison-table-th--left { text-align: left; }
  .comparison-table-th--center { text-align: center; }

  .comparison-table-row {
    border-bottom: 1px solid #e0e0e0;
    transition: background-color 0.15s;
  }
  .comparison-table-row:last-child {
    border-bottom: none;
  }
  .comparison-table-row:hover {
    background-color: #fafafa;
  }
  .comparison-table-row--highlight {
    background-color: rgba(239, 122, 26, 0.04);
  }
  .comparison-table-row--highlight:hover {
    background-color: rgba(239, 122, 26, 0.08);
  }

  .comparison-table-td {
    padding: 0.625rem 0.75rem;
    color: #333;
    line-height: 1.5;
    vertical-align: middle;
  }
  .comparison-table-td--center { text-align: center; }
  .comparison-table-td--left:first-child {
    font-weight: 600;
    color: #242424;
  }
</style>
