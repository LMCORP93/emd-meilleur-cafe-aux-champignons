---
interface NavLink {
  label: string;
  href: string;
}

interface Props {
  siteName: string;
  logoSrc: string;
  navLinks: NavLink[];
  ctaText: string;
  ctaLink: string;
}

const { siteName, logoSrc, navLinks, ctaText, ctaLink } = Astro.props;
---

<header
  id="navbar"
  class="navbar fixed top-0 left-0 right-0 z-50 transition-shadow duration-300"
  style="background-color: #f4f2ec;"
>
  <div class="navbar-inner mx-auto flex h-[80px] items-center justify-between px-[40px] max-lg:px-6 max-md:h-[72px] max-md:px-5" style="max-width: 72rem;">
    <!-- Logo (left, no text) -->
    <a href="/" class="flex shrink-0 items-center">
      <img src={logoSrc} alt={siteName} class="h-[40px] w-auto max-md:h-[32px]" />
    </a>

    <!-- Desktop Nav Links (centered) -->
    <nav class="hidden items-center gap-8 lg:flex">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="nav-link font-heading text-[16px] font-medium leading-none text-[#595b61] transition-colors duration-200 hover:text-text-dark"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Desktop CTA Button (right) -->
    <a
      href={ctaLink}
      rel="nofollow sponsored"
      target="_blank"
      class="cta-btn hidden items-center gap-2 lg:inline-flex"
    >
      <span>{ctaText}</span>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="shrink-0"
      >
        <path d="M5 12h14" />
        <path d="m12 5 7 7-7 7" />
      </svg>
    </a>

    <!-- Mobile Hamburger -->
    <button
      id="mobile-menu-btn"
      class="flex flex-col items-center justify-center gap-[6px] lg:hidden"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
    >
      <span class="hamburger-bar block h-[2px] w-[24px] origin-center bg-text-dark transition-all duration-300"></span>
      <span class="hamburger-bar block h-[2px] w-[24px] bg-text-dark transition-all duration-300"></span>
      <span class="hamburger-bar block h-[2px] w-[24px] origin-center bg-text-dark transition-all duration-300"></span>
    </button>
  </div>

  <!-- Thin grey separator -->
  <div class="h-px w-full" style="background-color: rgba(0,0,0,0.1);"></div>

  <!-- Mobile Menu Overlay (full-screen) -->
  <div
    id="mobile-menu"
    class="mobile-overlay fixed inset-0 z-[-1] flex flex-col items-center justify-center gap-10 opacity-0 transition-all duration-300 lg:hidden"
    style="background-color: #f4f2ec;"
  >
    <button
      id="mobile-menu-close"
      class="absolute right-5 top-[22px] flex h-10 w-10 items-center justify-center"
      aria-label="Fermer le menu"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="#242424"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M18 6 6 18" />
        <path d="m6 6 12 12" />
      </svg>
    </button>

    <nav class="flex flex-col items-center gap-7">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="mobile-link font-heading text-[28px] font-semibold leading-tight text-text-dark transition-colors duration-200 hover:text-primary"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <a
      href={ctaLink}
      rel="nofollow sponsored"
      target="_blank"
      class="cta-btn-mobile mt-2 inline-flex items-center gap-2.5"
    >
      <span>{ctaText}</span>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="shrink-0"
      >
        <path d="M5 12h14" />
        <path d="m12 5 7 7-7 7" />
      </svg>
    </a>
  </div>
</header>

<!-- Spacer to offset fixed navbar -->
<div class="navbar-spacer"></div>

<style>
  /* ── Navbar dimensions ── */
  .navbar-spacer {
    height: calc(80px + 1px);
  }
  @media (max-width: 767px) {
    .navbar-spacer {
      height: calc(72px + 1px);
    }
  }

  /* ── Navbar shadow on scroll ── */
  .navbar.scrolled {
    box-shadow: 0 1px 10px 0 rgba(0, 0, 0, 0.1);
  }

  /* ── Desktop CTA button ── */
  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background-color: #ef7a1a;
    color: #ffffff;
    font-family: 'Archivo', system-ui, sans-serif;
    font-weight: 700;
    font-size: 0.875rem;
    line-height: 1;
    padding: 0.8125rem 1.625rem;
    border-radius: 8px;
    letter-spacing: 0.01em;
    transition: background-color 0.2s ease, transform 0.2s ease;
    text-decoration: none;
    white-space: nowrap;
  }

  .cta-btn:hover {
    background-color: #d66a12;
    transform: translateY(-1px);
  }

  /* ── Mobile CTA button ── */
  .cta-btn-mobile {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    background-color: #ef7a1a;
    color: #ffffff;
    font-family: 'Archivo', system-ui, sans-serif;
    font-weight: 700;
    font-size: 1.125rem;
    line-height: 1;
    padding: 1rem 2rem;
    border-radius: 8px;
    letter-spacing: 0.01em;
    transition: background-color 0.2s ease;
    text-decoration: none;
    white-space: nowrap;
  }

  .cta-btn-mobile:hover {
    background-color: #d66a12;
  }

  /* ── Mobile menu open state ── */
  .mobile-overlay.open {
    opacity: 1;
    z-index: 60;
  }

  /* ── Hamburger → X animation ── */
  .hamburger-bar.active:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }

  .hamburger-bar.active:nth-child(2) {
    opacity: 0;
  }

  .hamburger-bar.active:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }
</style>

<script>
  // ── Navbar shadow on scroll ──
  const navbar = document.getElementById('navbar');
  if (navbar) {
    const onScroll = () => {
      if (window.scrollY > 10) {
        navbar.classList.add('scrolled');
      } else {
        navbar.classList.remove('scrolled');
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  // ── Mobile menu ──
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const closeBtn = document.getElementById('mobile-menu-close');
  const bars = btn?.querySelectorAll('.hamburger-bar');

  if (btn && menu && closeBtn && bars) {
    const openMenu = () => {
      menu.classList.add('open');
      bars.forEach((bar) => bar.classList.add('active'));
      document.body.style.overflow = 'hidden';
      btn.setAttribute('aria-expanded', 'true');
    };

    const closeMenu = () => {
      menu.classList.remove('open');
      bars.forEach((bar) => bar.classList.remove('active'));
      document.body.style.overflow = '';
      btn.setAttribute('aria-expanded', 'false');
    };

    btn.addEventListener('click', () => {
      const isOpen = menu.classList.contains('open');
      isOpen ? closeMenu() : openMenu();
    });

    closeBtn.addEventListener('click', closeMenu);

    // Close on link click
    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });

    // Close on Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menu.classList.contains('open')) {
        closeMenu();
      }
    });
  }
</script>
